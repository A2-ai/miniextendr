#!/bin/bash
# miniextendr pre-commit hook
# Checks: cargo fmt, stale configure, stale vendor tarball
# Installed by minirextendr::use_miniextendr_git_hooks()

set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# ── Locate the R package directory ───────────────────────────────────────────
# In a monorepo the R package lives in a subdirectory; in a standalone package
# it's the repo root. Detect by looking for src/rust/Cargo.toml.

RPKG_DIR=""
if [ -f "src/rust/Cargo.toml" ]; then
    RPKG_DIR="."
else
    # Search one level deep for an R package subdirectory
    for d in */; do
        if [ -f "${d}src/rust/Cargo.toml" ]; then
            RPKG_DIR="${d%/}"
            break
        fi
    done
fi

if [ -z "$RPKG_DIR" ]; then
    # Not a miniextendr package — nothing to check
    exit 0
fi

# Prefix for matching staged files (empty for root, "rpkg/" for monorepo)
if [ "$RPKG_DIR" = "." ]; then
    PREFIX=""
else
    PREFIX="${RPKG_DIR}/"
fi

# ── cargo fmt ────────────────────────────────────────────────────────────────
STAGED_RS=$(echo "$STAGED" | grep -E "^${PREFIX}src/rust/.*\.rs$" || true)
if [ -n "$STAGED_RS" ]; then
    CARGO_TOML="${RPKG_DIR}/src/rust/Cargo.toml"
    if [ -f "$CARGO_TOML" ]; then
        echo "pre-commit: checking Rust formatting..."
        if ! cargo fmt --manifest-path "$CARGO_TOML" -- --check >/dev/null 2>&1; then
            echo "BLOCKED: cargo fmt check failed."
            echo "Run: cargo fmt --manifest-path $CARGO_TOML"
            exit 1
        fi
        echo "pre-commit: Rust formatting OK."
    fi
fi

# ── Stale configure script ──────────────────────────────────────────────────
STAGED_CONFIGURE_AC=$(echo "$STAGED" | grep -E "^${PREFIX}configure\.ac$" || true)
STAGED_CONFIGURE=$(echo "$STAGED" | grep -E "^${PREFIX}configure$" || true)
if [ -n "$STAGED_CONFIGURE_AC" ] && [ -z "$STAGED_CONFIGURE" ]; then
    echo "WARNING: configure.ac is staged but configure is not."
    echo "  Run: cd ${RPKG_DIR} && autoconf"
    echo "  Then stage the updated configure script."
    exit 1
fi

# ── Stale NAMESPACE (wrappers changed without roxygen2) ─────────────────────
# R/*-wrappers.R is auto-generated by the Rust build. After it changes,
# devtools::document() must run to update NAMESPACE and man pages.
STAGED_WRAPPERS=$(echo "$STAGED" | grep -E "^${PREFIX}R/.*-wrappers\.R$" || true)
STAGED_NAMESPACE=$(echo "$STAGED" | grep -E "^${PREFIX}NAMESPACE$" || true)
if [ -n "$STAGED_WRAPPERS" ] && [ -z "$STAGED_NAMESPACE" ]; then
    echo "BLOCKED: R/*-wrappers.R changed but NAMESPACE was not updated."
    echo "  Run: devtools::document()  (or: just devtools-document)"
    echo "  Then stage the updated NAMESPACE and man/ pages."
    exit 1
fi

# ── Stale vendor tarball ────────────────────────────────────────────────────
# If Rust sources changed, check that inst/vendor.tar.xz isn't stale.
# This is a warning, not a blocker — vendor tarball updates are heavy.
STAGED_RUST=$(echo "$STAGED" | grep -E "^${PREFIX}src/rust/" || true)
STAGED_VENDOR=$(echo "$STAGED" | grep -E "^${PREFIX}inst/vendor\.tar\.xz$" || true)
if [ -n "$STAGED_RUST" ] && [ -z "$STAGED_VENDOR" ]; then
    VENDOR_TARBALL="${RPKG_DIR}/inst/vendor.tar.xz"
    if [ -f "$VENDOR_TARBALL" ]; then
        echo "NOTE: Rust sources changed but inst/vendor.tar.xz was not updated."
        echo "  If you changed dependencies, run: cargo revendor (or just vendor)"
        echo "  This is a reminder, not a blocker."
    fi
fi

echo "pre-commit: all miniextendr checks passed."
