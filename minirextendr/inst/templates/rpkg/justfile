# {{{package}}} - R package with Rust backend
#
# Quick reference:
#   just                  - Show available recipes
#   just cargo check      - Run cargo check
#   just cargo test       - Run cargo tests
#   just cargo clippy     - Run lints
#   just cargo fmt        - Format Rust code
#   just configure        - Configure R package build
#   just install          - Build and install R package
#   just rtest            - Run R package tests
#   just rdoc             - Generate R documentation
#   just version-sync     - Sync versions across DESCRIPTION/Cargo.toml

set shell := ["bash", "-euo", "pipefail", "-c"]

# Rust manifest location
manifest := "src/rust/Cargo.toml"

# Default recipe - show available commands
default:
    @just --list

# ============================================================================
# Rust development
# ============================================================================

# Run any cargo subcommand (e.g., just cargo check, just cargo test --release)
cargo subcmd *args:
    cargo {{subcmd}} --manifest-path={{manifest}} {{args}}

# Common cargo shortcuts
check *args: (cargo "check" args)
test *args: (cargo "test" args)
clippy *args: (cargo "clippy" args)
fmt *args: (cargo "fmt" args)
build *args: (cargo "build" "--release" args)
doc *args: (cargo "doc" "--document-private-items" args)
tree *args: (cargo "tree" args)
expand *args: (cargo "expand" "--lib" args)

# Clean Rust build artifacts
clean:
    cargo clean --manifest-path={{manifest}}
    rm -rf vendor
    rm -f inst/vendor.tar.xz

# ============================================================================
# R package development
# ============================================================================

# Internal: abort if inst/vendor.tar.xz is present in the source tree.
# inst/vendor.tar.xz is the single signal that flips configure into tarball
# mode. Dev-consume recipes wire this guard to prevent silent tarball-mode
# iteration when the file is left over from a previous cran-prep run.
# Producer recipes (cran-prep, rbuild, rcheck) are intentionally excluded.
[private]
[script("bash")]
_assert-no-vendor-leak:
    set -euo pipefail
    if [ -f inst/vendor.tar.xz ]; then
        printf '%s\n' \
          "error: inst/vendor.tar.xz is present in the source tree." \
          "" \
          "This file is produced by 'just vendor' / 'just cran-prep' for CRAN" \
          "submission. When present, configure flips into tarball/offline mode," \
          "which ignores cargo's normal dependency resolution." \
          "" \
          "Fix:  rm inst/vendor.tar.xz && just configure" \
          >&2
        exit 1
    fi

# Configure the R package (generate Makevars and build files)
#
# This must be run before any R CMD operation. It:
# 1. Generates src/Makevars from src/Makevars.in
# 2. Detects install mode: tarball (inst/vendor.tar.xz present) or source (cargo git deps)
# Source installs (R CMD INSTALL ., devtools::*) never need vendoring — cargo resolves deps.
configure:
    bash ./configure

# Build and install R package with R CMD INSTALL
install *args: _assert-no-vendor-leak configure
    R CMD INSTALL {{args}} .

# Run R package tests with devtools
rtest FILTER="": _assert-no-vendor-leak configure
    #!/usr/bin/env bash
    if [ -z "{{FILTER}}" ]; then
      Rscript -e 'devtools::test(".")'
    else
      Rscript -e 'devtools::test(".", filter = "{{FILTER}}")'
    fi

# Generate R documentation with devtools/roxygen2
rdoc: configure
    Rscript -e 'devtools::document(".")'

# Load package with devtools::load_all (for interactive development)
load: _assert-no-vendor-leak configure
    Rscript -e 'devtools::load_all(".")'

# Install with devtools::install
devtools-install: _assert-no-vendor-leak configure
    Rscript -e 'devtools::install(".")'

# Build R package tarball
rbuild *args: configure
    R CMD build {{args}} .

# Run R CMD check
rcheck: configure
    Rscript -e "rcmdcheck::rcmdcheck('.', args = c('--as-cran', '--no-manual'), error_on = 'warning')"

# Run devtools::check
devtools-check: configure
    Rscript -e 'devtools::check(".", error_on = "error")'

# ============================================================================
# Development workflow shortcuts
# ============================================================================

# Full development cycle: check Rust, test Rust, install R package
dev: check test install

# Quick iteration: just reinstall R package
reinstall: install

# Vendor all dependencies for CRAN submission
# Creates inst/vendor.tar.xz — include in CRAN tarball (R CMD build bundles it automatically).
# Requires cargo-revendor: cargo install --git https://github.com/A2-ai/miniextendr cargo-revendor
vendor:
    cargo revendor \
      --manifest-path src/rust/Cargo.toml \
      --output vendor \
      --strip-toml-sections \
      --compress inst/vendor.tar.xz \
      --blank-md \
      --source-marker \
      --force \
      -v

# Prepare for CRAN submission: vendor deps, build, check
#
# Cleanup: rpkg/inst/vendor.tar.xz must be removed after the build/check
# pipeline. Otherwise the leftover in the source tree makes the next
# `just install` / `devtools::install(".")` silently switch to tarball mode
# (configure's only signal is `[ -f inst/vendor.tar.xz ]`), which freezes out
# any cargo-resolved dependency edits.
cran-prep: vendor rbuild rcheck
    # TODO(#454): trap-clean on failure — see issue #454
    rm -f inst/vendor.tar.xz

# ============================================================================
# Version management
# ============================================================================

# Sync Cargo.toml and configure.ac versions to match DESCRIPTION
version-sync:
    Rscript tools/bump-version.R --sync

# Bump patch version (0.1.0 -> 0.1.1)
version-bump-patch:
    Rscript tools/bump-version.R --bump=patch

# Bump minor version (0.1.0 -> 0.2.0)
version-bump-minor:
    Rscript tools/bump-version.R --bump=minor

# Bump major version (0.1.0 -> 1.0.0)
version-bump-major:
    Rscript tools/bump-version.R --bump=major

# Add/increment dev version (0.1.0 -> 0.1.0.9000, or 0.1.0.9000 -> 0.1.0.9001)
version-bump-dev:
    Rscript tools/bump-version.R --bump=dev+

# Set specific version (e.g., just version-set 1.2.3)
version-set ver:
    Rscript tools/bump-version.R --set={{ver}}
