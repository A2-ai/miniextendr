## --- filled by configure ----------------------------------------------
ABS_TOP_SRCDIR        = @ABS_TOP_SRCDIR@
ABS_RPKG_SRCDIR       = @ABS_RPKG_SRCDIR@
CARGO                 = @CARGO@
RUST_TOOLCHAIN        = @RUST_TOOLCHAIN@
CARGO_TARGET_DIR      = @CARGO_TARGET_DIR@
CARGO_PROFILE         = @CARGO_PROFILE@
CARGO_STATICLIB_NAME  = @CARGO_STATICLIB_NAME@
ENV_RUSTFLAGS         = @ENV_RUSTFLAGS@
CARGO_HOME            = @CARGO_HOME@
CARGO_BUILD_TARGET    = @CARGO_BUILD_TARGET@
ABS_RPKG_SRC_CARGO    = @ABS_RPKG_SRC_CARGO@
CARGO_LIBDIR          = @CARGO_LIBDIR@
VENDOR_OUT            = @VENDOR_OUT@
CARGO_OFFLINE_FLAG    = @CARGO_OFFLINE_FLAG@
IS_TARBALL_INSTALL    = @IS_TARBALL_INSTALL@
CARGO_FEATURES_FLAG   = @CARGO_FEATURES_FLAG@
TAR_FORCE_LOCAL       = @TAR_FORCE_LOCAL@
NATIVE_PKG_CPPFLAGS   = @NATIVE_PKG_CPPFLAGS@
IS_WASM_INSTALL       = @IS_WASM_INSTALL@
CARGO_BUILD_STD_FLAG  = @CARGO_BUILD_STD_FLAG@

CARGO_AR = $(CARGO_LIBDIR)/lib$(CARGO_STATICLIB_NAME).a
# codegen-units = 1 in Cargo.toml forces the user crate into a single .o (NATIVE path).
# On wasm32-*, registration goes via wasm_registry.rs (ordinary symbol refs), not linkme,
# so the setting is inert there.
PKG_LIBS = $(CARGO_AR)
PKG_CPPFLAGS = $(NATIVE_PKG_CPPFLAGS)

CARGO_TOML = $(ABS_RPKG_SRCDIR)/rust/Cargo.toml
WRAPPERS_R = $(ABS_TOP_SRCDIR)/R/@PACKAGE_NAME@-wrappers.R
# wasm32 snapshot — generated alongside WRAPPERS_R from the same wrapper-gen pass.
# Lives in the user crate's source tree (not target/) because miniextendr_init!
# expects it at `<crate>/src/rust/wasm_registry.rs` for `mod __miniextendr_wasm_registry;`
# to resolve when cross-compiling for `wasm32-*`.
WASM_REGISTRY_RS = $(ABS_RPKG_SRCDIR)/rust/wasm_registry.rs
## ----------------------------------------------------------------------
export CARGO_HOME

# FORCE_CARGO: phony target to ensure Cargo is invoked every time make runs,
# letting Cargo's own incremental compilation decide what to rebuild.
.PHONY: all clean FORCE_CARGO

# all must be defined FIRST to be the default target.
# Depend on both $(SHLIB) and $(WRAPPERS_R) so that:
#   1. $(SHLIB) (the installed shared object) is linked from the staticlib first.
#   2. $(WRAPPERS_R) loads that same $(SHLIB) and calls back into it to emit the
#      R wrappers — no separate cdylib build. The .so is already a loadable shared
#      object and carries every linkme #[distributed_slice] entry (force-loaded via
#      stub.c + codegen-units = 1), so it produces exactly what a throwaway cdylib did.
#   On wasm32/tarball: the wrapper-gen recipe is a no-op, so the committed
#   wrappers are reused without loading anything.
all: $(SHLIB) $(WRAPPERS_R)
	@# Source install: touch Cargo.toml so pkgbuild always thinks sources changed
	@# (dev iteration with devtools::load_all() / install() relies on this).
	@if [ "$(IS_TARBALL_INSTALL)" != "true" ]; then \
	  touch "$(CARGO_TOML)"; \
	fi
	@# Tarball install: scrub vendor and target dirs after build to save space
	@# in the installed package. Gate on IS_TARBALL_INSTALL so dev installs
	@# don't blow away in-progress build state.
	@if [ "$(IS_TARBALL_INSTALL)" = "true" ]; then \
	  set -e; \
	  if [ -n "$(VENDOR_OUT)" ] && [ -d "$(VENDOR_OUT)" ]; then rm -rf "$(VENDOR_OUT)"; fi; \
	  if [ -d "$(CARGO_TARGET_DIR)" ]; then rm -rf "$(CARGO_TARGET_DIR)"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/.cargo" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/.cargo"; fi; \
	  if [ -d "$(ABS_TOP_SRCDIR)/rust-target" ]; then rm -rf "$(ABS_TOP_SRCDIR)/rust-target"; fi; \
	  if [ -d "$(ABS_TOP_SRCDIR)/ra-target" ]; then rm -rf "$(ABS_TOP_SRCDIR)/ra-target"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/target" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/target"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/ra_target" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/ra_target"; fi; \
	fi

# Phony target to force Cargo invocation (no recipe - just triggers dependents)
FORCE_CARGO:

$(SHLIB): $(OBJECTS) $(CARGO_AR)

# Build the Rust static library
# FORCE_CARGO ensures Cargo is always invoked; Cargo handles incremental builds.
# Vendor extraction (when in tarball-install mode) is handled by configure.
#
# OBJECTS are passed to cargo as link-args so the Rust crate can reference
# symbols from C shim files (bindgen-generated static inline wrappers).
#
# Note: configure.ac emits an [env] block in src/rust/.cargo/config.toml with
# platform-derived MACOSX_DEPLOYMENT_TARGET (macOS), CARGO_TARGET_*_LINKER
# (Windows rtools), and AR_<target> overrides. Cargo inherits these on every
# invocation below; they ensure the Rust staticlib's ABI matches R's build.
# To override, set the variable in your shell — shell env wins over [env].
# See `bash ./configure` output for the values actually emitted.
$(CARGO_AR): FORCE_CARGO $(OBJECTS)
	@set -e; \
	TARGET_OPT=""; \
	LINK_ARGS=""; \
	for obj in $(OBJECTS); do LINK_ARGS="$$LINK_ARGS -C link-arg=$(ABS_RPKG_SRCDIR)/$$obj"; done; \
	if [ -n "$(CARGO_BUILD_TARGET)" ]; then TARGET_OPT="--target $(CARGO_BUILD_TARGET)"; fi; \
	cd "$(ABS_RPKG_SRCDIR)/rust"; \
	RUSTFLAGS="$(ENV_RUSTFLAGS) $$LINK_ARGS" \
	$(CARGO) $(RUST_TOOLCHAIN) build $(CARGO_OFFLINE_FLAG) $(CARGO_FEATURES_FLAG) $(CARGO_BUILD_STD_FLAG) $$TARGET_OPT \
	  --lib --profile $(CARGO_PROFILE) \
	  --manifest-path $(CARGO_TOML) \
	  --target-dir $(CARGO_TARGET_DIR); \
	test -f "$(CARGO_AR)"

# Automatic R wrapper + wasm32 snapshot generation.
# Loads the freshly-linked $(SHLIB) — the installed shared object — in R and
# calls (a) miniextendr_write_wrappers() which writes R/*-wrappers.R and
# (b) miniextendr_write_wasm_registry() which writes src/rust/wasm_registry.rs.
# Both walk the linkme #[distributed_slice] tables that stub.c force-loads into
# $(SHLIB) (codegen-units = 1), so the installed .so produces exactly what a
# throwaway cdylib used to — no separate cdylib build/link. Both writers diff
# old vs new and only overwrite when content changes (the Rust wasm_registry.rs
# is read by `miniextendr_init!()` macro expansion when cross-compiling for
# wasm32 — host edits to `#[miniextendr]` items must be matched by a regenerated
# wasm_registry.rs or the wasm32 build registers stale routines).
# NAMESPACE is NOT generated here — use devtools::document() for that.
#
# dyn.load($(SHLIB)) runs R_init_<pkg>; MINIEXTENDR_WRAPPER_GEN=1 makes it take a
# minimal init path (register routines only — see init.rs::package_init). The two
# writers are registered routines (registry.rs), so getNativeSymbolInfo finds
# them on every platform — no cdylib-exports.def / win.def entry needed.
#
# Three-way split on build mode, branched at the shell level (not with GNU make
# ifeq/ifndef conditionals) so this Makevars stays portable POSIX make and the
# package needs no "SystemRequirements: GNU make".
#   wasm32  : $(SHLIB) is a .wasm SIDE_MODULE that host R cannot dyn.load;
#             expects pre-generated files from the host devtools::document() pass.
#   tarball : R/<pkg>-wrappers.R is already committed and ships in the tarball,
#             so skip loading $(SHLIB) for wrapper-gen entirely (#1022). The
#             pre-commit hook guarantees the shipped wrappers match the Rust code.
#             LOAD-BEARING GUARD: skip only when R/<pkg>-wrappers.R exists AND is
#             non-empty ([ -s ]). If it is absent or empty (a tarball stripped of
#             its wrappers, a truncated download, etc.), FALL BACK to full
#             wrapper-gen rather than installing a wrapper-less, silently-broken
#             package. Set MINIEXTENDR_FORCE_WRAPPER_GEN to force regeneration
#             even when the shipped wrappers are valid (debugging only).
#   dev     : load $(SHLIB) + generate wrappers (normal dev/CI flow).
$(WRAPPERS_R): $(SHLIB)
	@set -e; \
	if [ "$(IS_WASM_INSTALL)" = "true" ]; then \
	  echo "wasm32 install: skipping wrapper-gen (pre-generated R/@PACKAGE_NAME@-wrappers.R + src/rust/wasm_registry.rs expected)"; \
	  touch '$(WRAPPERS_R)'; \
	elif [ "$(IS_TARBALL_INSTALL)" = "true" ] && [ -z "$$MINIEXTENDR_FORCE_WRAPPER_GEN" ] && [ -s '$(WRAPPERS_R)' ]; then \
	  echo "tarball install: using pre-shipped R/@PACKAGE_NAME@-wrappers.R (skipping wrapper-gen, #1022)"; \
	  touch '$(WRAPPERS_R)'; \
	else \
	  if [ "$(IS_TARBALL_INSTALL)" = "true" ] && [ -n "$$MINIEXTENDR_FORCE_WRAPPER_GEN" ]; then \
	    echo "MINIEXTENDR_FORCE_WRAPPER_GEN set: regenerating wrappers from $(SHLIB) (tarball mode override)..."; \
	  elif [ "$(IS_TARBALL_INSTALL)" = "true" ]; then \
	    echo "tarball install: pre-shipped R/@PACKAGE_NAME@-wrappers.R absent or empty — falling back to full wrapper-gen (#1022 guard)..." >&2; \
	  else \
	    echo "Generating R wrappers + wasm_registry.rs..."; \
	  fi; \
	  _shlib='$(ABS_RPKG_SRCDIR)/$(SHLIB)'; \
	  _wrappers='$(WRAPPERS_R)'; \
	  _wasm_registry='$(WASM_REGISTRY_RS)'; \
	  if command -v cygpath >/dev/null 2>&1; then \
	    _shlib=$$(cygpath -m "$$_shlib"); \
	    _wrappers=$$(cygpath -m "$$_wrappers"); \
	    _wasm_registry=$$(cygpath -m "$$_wasm_registry"); \
	  fi; \
	  MINIEXTENDR_WRAPPER_GEN=1 "$(R_HOME)/bin$(R_ARCH)/Rscript" -e "invisible(local({ lib <- dyn.load('$$_shlib'); .Call(getNativeSymbolInfo('miniextendr_write_wrappers', lib), '$$_wrappers'); .Call(getNativeSymbolInfo('miniextendr_write_wasm_registry', lib), '$$_wasm_registry'); dyn.unload('$$_shlib') }))"; \
	fi

clean:
