## --- filled by configure ----------------------------------------------
ABS_TOP_SRCDIR        = @ABS_TOP_SRCDIR@
ABS_RPKG_SRCDIR       = @ABS_RPKG_SRCDIR@
CARGO                 = @CARGO@
RUST_TOOLCHAIN        = @RUST_TOOLCHAIN@
CARGO_TARGET_DIR      = @CARGO_TARGET_DIR@
CARGO_PROFILE         = @CARGO_PROFILE@
CARGO_STATICLIB_NAME  = @CARGO_STATICLIB_NAME@
ENV_RUSTFLAGS         = @ENV_RUSTFLAGS@
CARGO_BUILD_TARGET    = @CARGO_BUILD_TARGET@
ABS_RPKG_SRC_CARGO    = @ABS_RPKG_SRC_CARGO@
CARGO_LIBDIR          = @CARGO_LIBDIR@
VENDOR_OUT            = @VENDOR_OUT@
CARGO_OFFLINE_FLAG    = @CARGO_OFFLINE_FLAG@
IS_TARBALL_INSTALL    = @IS_TARBALL_INSTALL@
CARGO_FEATURES_FLAG   = @CARGO_FEATURES_FLAG@
CDYLIB_PREFIX         = @CDYLIB_PREFIX@
CDYLIB_EXT            = @CDYLIB_EXT@
TAR_FORCE_LOCAL       = @TAR_FORCE_LOCAL@
NATIVE_PKG_CPPFLAGS   = @NATIVE_PKG_CPPFLAGS@
IS_WASM_INSTALL       = @IS_WASM_INSTALL@
CARGO_BUILD_STD_FLAG  = @CARGO_BUILD_STD_FLAG@

CARGO_AR = $(CARGO_LIBDIR)/lib$(CARGO_STATICLIB_NAME).a
# codegen-units = 1 in Cargo.toml ensures the user crate compiles into a single .o
# inside the staticlib archive. The linker pulls it in (via R_init_<pkg>), which
# brings all linkme distributed_slice entries along — no force_load needed.
PKG_LIBS = $(CARGO_AR)
PKG_CPPFLAGS = $(NATIVE_PKG_CPPFLAGS)

CARGO_TOML = $(ABS_RPKG_SRCDIR)/rust/Cargo.toml
WRAPPERS_R = $(ABS_TOP_SRCDIR)/R/@PACKAGE_NAME@-wrappers.R
# wasm32 snapshot — generated alongside WRAPPERS_R from the same cdylib pass.
# Lives in the user crate's source tree (not target/) because miniextendr_init!
# expects it at `<crate>/src/rust/wasm_registry.rs` for `mod __miniextendr_wasm_registry;`
# to resolve when cross-compiling for `wasm32-*`.
WASM_REGISTRY_RS = $(ABS_RPKG_SRCDIR)/rust/wasm_registry.rs

# cdylib for R wrapper generation (platform-specific extension)
CARGO_CDYLIB = $(CARGO_LIBDIR)/$(CDYLIB_PREFIX)$(CARGO_STATICLIB_NAME).$(CDYLIB_EXT)
## ----------------------------------------------------------------------

# FORCE_CARGO: phony target to ensure Cargo is invoked every time make runs,
# letting Cargo's own incremental compilation decide what to rebuild.
.PHONY: all clean FORCE_CARGO

# all must be defined FIRST to be the default target.
# Depend on both $(SHLIB) and $(WRAPPERS_R) so that:
#   1. Staticlib builds first ($(SHLIB) needs $(CARGO_AR)), warming the incremental cache
#   2. On native: cdylib builds second ($(WRAPPERS_R) needs $(CARGO_CDYLIB)), fast from warm cache
#   3. On native: R wrappers are generated from the cdylib
#   On wasm32: $(WRAPPERS_R) has no cdylib prereq — pre-generated files are expected.
all: $(SHLIB) $(WRAPPERS_R)
	@# Source install: touch Cargo.toml so pkgbuild always thinks sources changed
	@# (dev iteration with devtools::load_all() / install() relies on this).
	@if [ "$(IS_TARBALL_INSTALL)" != "true" ]; then \
	  touch "$(CARGO_TOML)"; \
	fi
	@# Tarball install: scrub vendor and target dirs after build to save space
	@# in the installed package. Gate on IS_TARBALL_INSTALL so dev installs
	@# don't blow away in-progress build state.
	@if [ "$(IS_TARBALL_INSTALL)" = "true" ]; then \
	  set -e; \
	  if [ -n "$(VENDOR_OUT)" ] && [ -d "$(VENDOR_OUT)" ]; then rm -rf "$(VENDOR_OUT)"; fi; \
	  if [ -d "$(CARGO_TARGET_DIR)" ]; then rm -rf "$(CARGO_TARGET_DIR)"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/.cargo" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/.cargo"; fi; \
	  if [ -d "$(ABS_TOP_SRCDIR)/rust-target" ]; then rm -rf "$(ABS_TOP_SRCDIR)/rust-target"; fi; \
	  if [ -d "$(ABS_TOP_SRCDIR)/ra-target" ]; then rm -rf "$(ABS_TOP_SRCDIR)/ra-target"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/target" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/target"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/ra_target" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/ra_target"; fi; \
	fi

# Phony target to force Cargo invocation (no recipe - just triggers dependents)
FORCE_CARGO:

$(SHLIB): $(OBJECTS) $(CARGO_AR)

# Build the Rust static library
# FORCE_CARGO ensures Cargo is always invoked; Cargo handles incremental builds.
# Vendor extraction (when in tarball-install mode) is handled by configure.
#
# OBJECTS are passed to cargo as link-args so the Rust crate can reference
# symbols from C shim files (bindgen-generated static inline wrappers).
$(CARGO_AR): FORCE_CARGO $(OBJECTS)
	@set -e; \
	TARGET_OPT=""; \
	LINK_ARGS=""; \
	for obj in $(OBJECTS); do LINK_ARGS="$$LINK_ARGS -C link-arg=$(ABS_RPKG_SRCDIR)/$$obj"; done; \
	if [ -n "$(CARGO_BUILD_TARGET)" ]; then TARGET_OPT="--target $(CARGO_BUILD_TARGET)"; fi; \
	cd "$(ABS_RPKG_SRCDIR)/rust"; \
	RUSTFLAGS="$(ENV_RUSTFLAGS) $$LINK_ARGS" \
	$(CARGO) $(RUST_TOOLCHAIN) build $(CARGO_OFFLINE_FLAG) $(CARGO_FEATURES_FLAG) $(CARGO_BUILD_STD_FLAG) $$TARGET_OPT \
	  --lib --profile $(CARGO_PROFILE) \
	  --manifest-path $(CARGO_TOML) \
	  --target-dir $(CARGO_TARGET_DIR); \
	test -f "$(CARGO_AR)"
	@# On Windows, remove cdylib .dll.a import lib so MinGW linker uses the staticlib.
	@rm -f '$(CARGO_LIBDIR)/lib$(CARGO_STATICLIB_NAME).dll.a'

# Automatic R wrapper + wasm32 snapshot generation.
# Builds a cdylib (shared library) containing all linkme distributed_slice
# entries, loads it in R, and calls (a) miniextendr_write_wrappers() which
# writes R/*-wrappers.R and (b) miniextendr_write_wasm_registry() which
# writes src/rust/wasm_registry.rs. Both writers diff old vs new and only
# overwrite when content changes (the Rust wasm_registry.rs is read by
# `miniextendr_init!()` macro expansion when cross-compiling for wasm32 —
# host edits to `#[miniextendr]` items must be matched by a regenerated
# wasm_registry.rs or the wasm32 build registers stale routines).
# NAMESPACE is NOT generated here — use devtools::document() for that.
#
# Three-way split on build mode:
#   wasm32  : cdylib is a .wasm SIDE_MODULE that host R cannot dyn.load;
#             expects pre-generated files from the host devtools::document() pass.
#   tarball : R/<pkg>-wrappers.R is already committed and ships in the tarball;
#             the cdylib regeneration would be a no-op (write-if-changed), so
#             skip the 10-30 s cdylib build entirely. Existence guard catches
#             a tarball that was manually stripped of its wrappers file.
#             Set MINIEXTENDR_FORCE_WRAPPER_GEN to override (debugging only).
#   dev     : full cdylib build + wrapper generation (normal dev/CI flow).
ifeq ($(IS_WASM_INSTALL),true)
$(WRAPPERS_R):
	@echo "wasm32 install: skipping wrapper-gen (pre-generated R/$(PACKAGE_NAME)-wrappers.R + src/rust/wasm_registry.rs expected)"
	@touch $(WRAPPERS_R)
else ifeq ($(IS_TARBALL_INSTALL),true)
ifndef MINIEXTENDR_FORCE_WRAPPER_GEN
$(WRAPPERS_R):
	@echo "tarball install: using pre-shipped R/$(PACKAGE_NAME)-wrappers.R"
	@if [ ! -f '$(WRAPPERS_R)' ]; then \
	  echo "ERROR: tarball is missing pre-generated $(WRAPPERS_R)" >&2; \
	  exit 1; \
	fi
	@touch $(WRAPPERS_R)
else
$(WRAPPERS_R): $(CARGO_CDYLIB)
	@echo "MINIEXTENDR_FORCE_WRAPPER_GEN set: regenerating wrappers from cdylib (tarball mode override)..."
	@_cdylib='$(CARGO_CDYLIB)'; \
	_wrappers='$(WRAPPERS_R)'; \
	_wasm_registry='$(WASM_REGISTRY_RS)'; \
	if command -v cygpath >/dev/null 2>&1; then \
	  _cdylib=$$(cygpath -m "$$_cdylib"); \
	  _wrappers=$$(cygpath -m "$$_wrappers"); \
	  _wasm_registry=$$(cygpath -m "$$_wasm_registry"); \
	fi; \
	MINIEXTENDR_CDYLIB_WRAPPERS=1 "$(R_HOME)/bin$(R_ARCH)/Rscript" -e "invisible(local({ lib <- dyn.load('$$_cdylib'); .Call(getNativeSymbolInfo('miniextendr_write_wrappers', lib), '$$_wrappers'); .Call(getNativeSymbolInfo('miniextendr_write_wasm_registry', lib), '$$_wasm_registry'); dyn.unload('$$_cdylib') }))"
	@echo "Removing cdylib to prevent linker collision with staticlib..."
	@rm -f '$(CARGO_CDYLIB)'
endif
else
$(WRAPPERS_R): $(CARGO_CDYLIB)
	@echo "Generating R wrappers + wasm_registry.rs..."
	@_cdylib='$(CARGO_CDYLIB)'; \
	_wrappers='$(WRAPPERS_R)'; \
	_wasm_registry='$(WASM_REGISTRY_RS)'; \
	if command -v cygpath >/dev/null 2>&1; then \
	  _cdylib=$$(cygpath -m "$$_cdylib"); \
	  _wrappers=$$(cygpath -m "$$_wrappers"); \
	  _wasm_registry=$$(cygpath -m "$$_wasm_registry"); \
	fi; \
	MINIEXTENDR_CDYLIB_WRAPPERS=1 "$(R_HOME)/bin$(R_ARCH)/Rscript" -e "invisible(local({ lib <- dyn.load('$$_cdylib'); .Call(getNativeSymbolInfo('miniextendr_write_wrappers', lib), '$$_wrappers'); .Call(getNativeSymbolInfo('miniextendr_write_wasm_registry', lib), '$$_wasm_registry'); dyn.unload('$$_cdylib') }))"
	@echo "Removing cdylib to prevent linker collision with staticlib..."
	@rm -f '$(CARGO_CDYLIB)'
endif

# Build cdylib for wrapper generation.
# Runs after staticlib (via `all` ordering), so the incremental cache is warm.
$(CARGO_CDYLIB): FORCE_CARGO $(OBJECTS) | $(CARGO_AR)
	@set -e; \
	TARGET_OPT=""; \
	CDYLIB_LINK_ARGS=""; \
	for obj in $(OBJECTS); do CDYLIB_LINK_ARGS="$$CDYLIB_LINK_ARGS -C link-arg=$(ABS_RPKG_SRCDIR)/$$obj"; done; \
	if [ -n "$(CARGO_BUILD_TARGET)" ]; then TARGET_OPT="--target $(CARGO_BUILD_TARGET)"; fi; \
	if [ "$(CDYLIB_EXT)" = "dll" ]; then \
	  CDYLIB_LINK_ARGS="$$CDYLIB_LINK_ARGS -C link-arg=-static-libgcc -C link-arg=$(ABS_RPKG_SRC_CARGO)/cdylib-exports.def -C link-arg=-Wl,--no-gc-sections"; \
	fi; \
	cd "$(ABS_RPKG_SRCDIR)/rust"; \
	RUSTFLAGS="$(ENV_RUSTFLAGS)" \
	$(CARGO) $(RUST_TOOLCHAIN) rustc $(CARGO_OFFLINE_FLAG) $(CARGO_FEATURES_FLAG) $$TARGET_OPT \
	  --lib --profile $(CARGO_PROFILE) \
	  --manifest-path $(CARGO_TOML) \
	  --target-dir $(CARGO_TARGET_DIR) \
	  --crate-type cdylib \
	  -- $$CDYLIB_LINK_ARGS

clean:
