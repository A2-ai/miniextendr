^LICENSE\.md$
^dev$

# Build artifacts and generated files
^src/rust/target$
^src/rust/ra_target$
^src/rust/\.cargo$
^\.cargo$
^src/.*\.o$
^src/.*\.so$
^src/.*\.dll$
^config\.log$
^config\.status$
^configure~$
^autom4te\.cache$

# Generated R wrapper (kept in src/, copied to R/)
^src/miniextendr_wrappers\.R$

# Development files
^bootstrap\.R$
^\.gitignore$
^\.DS_Store$

# R CMD check output
\.Rcheck$

# Vendor compression stamp file (dev-only)
^inst/\.vendor\.tar\.xz\.cksum$

# Vendor directory (ships via inst/vendor.tar.xz, not as loose files)
^vendor$

# Vendored crate metadata (causes R CMD check NOTEs/ERRORs)
\.cargo-checksum\.json$
\.cargo_vcs_info\.json$
^vendor/.*\.github$
^vendor/.*\.editorconfig$
^vendor/.*\.git-blame-ignore-revs$
^vendor/.*\.release-plz\.toml$
^vendor/.*\.rustfmt\.toml$
^vendor/.*\.travis\.yml$
\.vendor\.lock\.cksum$

# Static libraries in vendored crates (R CMD check objects NOTE)
^vendor/.*\.a$
^vendor/.*\.lib$
