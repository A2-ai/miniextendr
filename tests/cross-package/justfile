# Cross-package trait dispatch testing

just_bin_dir := justfile_directory() / ".." / ".." / "dev" / "just-bin"

set shell := ["../../dev/just-bin/bash", "-euo", "pipefail", "-c"]

export PATH := just_bin_dir + ":" + env("PATH", "")

default:
    @just --list

# Build and install both packages in sequence
build-all: configure-producer build-producer configure-consumer build-consumer

# Alias for build-all
install-all: build-all

# Document both packages (regenerate R wrappers)
document-all: document-producer document-consumer

# Document producer.pkg
document-producer: configure-producer
    #!/usr/bin/env bash
    set -euo pipefail
    FEATURES_FLAG=$(grep '^CARGO_FEATURES_FLAG' producer.pkg/src/Makevars | sed 's/^CARGO_FEATURES_FLAG *= *//')
    cargo rustc --lib --manifest-path producer.pkg/src/rust/Cargo.toml \
      --target-dir producer.pkg/src/rust/target $FEATURES_FLAG \
      --crate-type cdylib
    CRATE_NAME=$(grep '^name' producer.pkg/src/rust/Cargo.toml | head -1 | sed 's/.*= *"//;s/".*//' | tr '-' '_')
    if [[ "$OSTYPE" == "darwin"* ]]; then
      CDYLIB="producer.pkg/src/rust/target/debug/lib${CRATE_NAME}.dylib"
    elif [[ "$OSTYPE" == "msys"* ]] || [[ "$OSTYPE" == "win32"* ]]; then
      CDYLIB="producer.pkg/src/rust/target/debug/${CRATE_NAME}.dll"
    else
      CDYLIB="producer.pkg/src/rust/target/debug/lib${CRATE_NAME}.so"
    fi
    Rscript -e "
      lib <- dyn.load('${CDYLIB}')
      .Call(getNativeSymbolInfo('miniextendr_write_wrappers', lib), 'producer.pkg/R/producer.pkg-wrappers.R')
      dyn.unload('${CDYLIB}')
    "
    # Install first so roxygen2 can use load_installed (needed for R6 source refs)
    cd producer.pkg && Rscript -e 'devtools::install(".", upgrade=FALSE, quick=TRUE, keep_source=TRUE)'
    # Already in producer.pkg from previous line (bash shebang runs in one shell)
    Rscript -e 'roxygen2::roxygenise(load_code = roxygen2::load_installed)'

# Document consumer.pkg
document-consumer: document-producer configure-consumer
    #!/usr/bin/env bash
    set -euo pipefail
    FEATURES_FLAG=$(grep '^CARGO_FEATURES_FLAG' consumer.pkg/src/Makevars | sed 's/^CARGO_FEATURES_FLAG *= *//')
    cargo rustc --lib --manifest-path consumer.pkg/src/rust/Cargo.toml \
      --target-dir consumer.pkg/src/rust/target $FEATURES_FLAG \
      --crate-type cdylib
    CRATE_NAME=$(grep '^name' consumer.pkg/src/rust/Cargo.toml | head -1 | sed 's/.*= *"//;s/".*//' | tr '-' '_')
    if [[ "$OSTYPE" == "darwin"* ]]; then
      CDYLIB="consumer.pkg/src/rust/target/debug/lib${CRATE_NAME}.dylib"
    elif [[ "$OSTYPE" == "msys"* ]] || [[ "$OSTYPE" == "win32"* ]]; then
      CDYLIB="consumer.pkg/src/rust/target/debug/${CRATE_NAME}.dll"
    else
      CDYLIB="consumer.pkg/src/rust/target/debug/lib${CRATE_NAME}.so"
    fi
    Rscript -e "
      lib <- dyn.load('${CDYLIB}')
      .Call(getNativeSymbolInfo('miniextendr_write_wrappers', lib), 'consumer.pkg/R/consumer.pkg-wrappers.R')
      dyn.unload('${CDYLIB}')
    "
    # Install first so roxygen2 can use load_installed (needed for R6 source refs)
    cd consumer.pkg && Rscript -e 'devtools::install(".", upgrade=FALSE, quick=TRUE, keep_source=TRUE)'
    # Already in consumer.pkg from previous line (bash shebang runs in one shell)
    Rscript -e 'roxygen2::roxygenise(load_code = roxygen2::load_installed)'

# Configure both packages
configure-all: configure-producer configure-consumer

# Configure producer.pkg
configure-producer:
    cd producer.pkg && \
    if command -v autoconf >/dev/null 2>&1; then autoconf; else echo "autoconf not found; using existing configure"; fi && \
    bash ./configure

# Build and install producer.pkg
build-producer: configure-producer
    cd producer.pkg && Rscript -e 'devtools::install(".", upgrade=FALSE, quick=TRUE, keep_source=TRUE)'

# Configure consumer.pkg
configure-consumer:
    cd consumer.pkg && \
    if command -v autoconf >/dev/null 2>&1; then autoconf; else echo "autoconf not found; using existing configure"; fi && \
    bash ./configure

# Build and install consumer.pkg (must be built after producer)
build-consumer: build-producer configure-consumer
    cd consumer.pkg && Rscript -e 'devtools::install(".", upgrade=FALSE, quick=TRUE, keep_source=TRUE)'

# Test producer.pkg (uses installed package, not load_all)
test-producer: configure-producer
    cd producer.pkg && Rscript -e 'testthat::test_local(".", load_package = "installed")'

# Test consumer.pkg (includes cross-package tests, uses installed package)
test-consumer: configure-consumer
    cd consumer.pkg && Rscript -e 'testthat::test_local(".", load_package = "installed")'

# Run all tests
test-all: test-producer test-consumer

# Clean build artifacts from both packages
clean:
    cd producer.pkg && ./cleanup
    cd consumer.pkg && ./cleanup
    rm -rf producer.pkg/src/rust/target
    rm -rf consumer.pkg/src/rust/target
    rm -rf producer.pkg/rust-target
    rm -rf consumer.pkg/rust-target

# Alias for clean
clean-all: clean

# Full development cycle
dev: clean build-all test-all

# Quick rebuild (assumes configure already run)
rebuild: build-producer build-consumer

# Alias for rebuild
rebuild-all: rebuild

# Run R CMD check on producer.pkg
check-producer: configure-producer
    cd producer.pkg && Rscript -e 'devtools::check()'

# Run R CMD check on consumer.pkg
check-consumer: configure-consumer
    cd consumer.pkg && Rscript -e 'devtools::check()'

# Run R CMD check on both packages
check-all: check-producer check-consumer
