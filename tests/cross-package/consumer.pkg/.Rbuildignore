^LICENSE\.md$
^dev$

# Build artifacts and generated files
^rust-target$
^ra-target$
^src/rust/target$
^src/rust/ra_target$
^src/rust/\.cargo$
^src/.*\.o$
^src/.*\.so$
^src/.*\.dll$
^config\.log$
^config\.status$
^configure~$
^autom4te\.cache$

# Generated R wrapper (kept in src/, copied to R/)
^src/.*-wrappers\.R$

# Development files
^bootstrap\.R$
^\.gitignore$
^\.DS_Store$

# R CMD check output
\.Rcheck$
^\.cargo$
^inst/\.vendor\.tar\.xz\.cksum$
^vendor$
\.cargo-checksum\.json$
\.cargo_vcs_info\.json$
^vendor/.*\.github$
^vendor/.*\.editorconfig$
^vendor/.*\.git-blame-ignore-revs$
^vendor/.*\.release-plz\.toml$
^vendor/.*\.rustfmt\.toml$
^vendor/.*\.travis\.yml$
\.vendor\.lock\.cksum$
^vendor/.*\.a$
^vendor/.*\.lib$
