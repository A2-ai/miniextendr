{
  "files.associations": {
    "Makefile.in": "makefile",
    "Makefile.win": "makefile",
    "Makevars.in": "makefile",
    "Makevars.win.in": "makefile",
    "Makeconf.in": "makefile",
    "configure.ac": "m4",
    "*.ac": "m4",
    "NAMESPACE": "r",
    "DESCRIPTION": "yaml",
    "Cargo.toml.in": "toml"
  },
  "rust-analyzer.linkedProjects": [
    "Cargo.toml",
    "rpkg/src/rust/Cargo.toml"
  ],
  "rust-analyzer.cargo.extraArgs": [
    "--release", "--tests", "--benches", "--examples"
  ],
  "rust-analyzer.cargo.features": [
    "connections",
    "rayon",
    "rand",
    "rand_distr",
    "either",
    "ndarray",
    "nalgebra",
    "serde",
    "serde_json",
    "num-bigint",
    "rust_decimal",
    "ordered-float",
    "uuid",
    "regex",
    "indexmap",
    "time",
    "num-traits",
    "num-complex",
    "bytes",
    "url",
    "aho-corasick",
    "toml",
    "tabled",
    "sha2",
    "bitflags",
    "bitvec",
    "tinyvec",
    "vctrs",
    "raw_conversions",
    "macro-coverage",
    "materialization-tracking"
  ],
  "rust-analyzer.check.command": "clippy",
  // IMPORTANT: target directories MUST be outside rpkg/src/ to avoid pkgbuild
  // scanning generated .rs files in target/build/.../out/ which causes
  // unnecessary recompilation on every devtools::load_all()
  "rust-analyzer.cargo.targetDir": "${workspaceFolder}/rpkg/ra-target",
  "rust-analyzer.files.exclude": [
    "rpkg/vendor",
    "rpkg/src/rust/target",
    "rpkg/rust-target",
    "rpkg/ra-target"
  ],
  "terminal.integrated.env.osx": {
    "CARGO_TARGET_DIR": "${workspaceFolder}/rpkg/rust-target"
  },
  "terminal.integrated.env.linux": {
    "CARGO_TARGET_DIR": "${workspaceFolder}/rpkg/rust-target"
  },
  "terminal.integrated.env.windows": {
    "CARGO_TARGET_DIR": "${workspaceFolder}/rpkg/rust-target"
  },
  "[rust]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "files.exclude": {
    "**/target": true,
    "**/rust-target": true,
    "**/ra-target": true,
    "**/autom4te.cache": true,
    "**/*.o": true,
    "**/*.so": true,
    "**/*.a": true
  },
  "search.useIgnoreFiles": false,
  "search.exclude": {
    "**/target": true,
    "**/rust-target": true,
    "**/ra-target": true,
    "**/rpkg/vendor": true,
    "**/Cargo.lock": true,
    "**/*.Rcheck": true,
    "**/rpkg-check-output": true,
    "**/dvs_reviews": true,
    "**/dev_lib": true,
    "**/*.tar.gz": true,
    "**/background": true
  },
  "tinymist.formatterMode": "typstyle",
  "cSpell.enabled": false
}
