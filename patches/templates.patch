diff -ruN a/rpkg/document.rs.in b/rpkg/document.rs.in
--- a/rpkg/document.rs.in	1970-01-01 01:00:00
+++ b/rpkg/document.rs.in	2025-12-23 02:13:36
@@ -0,0 +1,34 @@
+use @CARGO_STATICLIB_NAME@::R_WRAPPERS_DEPS_@PACKAGE_TARNAME_RS_UPPERCASE@ as DEPS;
+use @CARGO_STATICLIB_NAME@::R_WRAPPERS_PARTS_@PACKAGE_TARNAME_RS_UPPERCASE@ as PARTS;
+use @CARGO_STATICLIB_NAME@::R_WRAPPERS_IMPLS_@PACKAGE_TARNAME_RS_UPPERCASE@ as IMPLS;
+use @CARGO_STATICLIB_NAME@::R_WRAPPERS_IMPL_DEPS_@PACKAGE_TARNAME_RS_UPPERCASE@ as IMPL_DEPS;
+
+fn main() {
+    let dep_flat: Vec<&'static str> = DEPS.concat();
+    let impl_dep_flat: Vec<&'static str> = IMPL_DEPS.concat();
+    let roots: [&[&'static str]; 4] = [PARTS, IMPLS, &dep_flat, &impl_dep_flat];
+
+    let mut f = std::fs::OpenOptions::new()
+        .write(true)
+        .truncate(true)
+        .create(true)
+        .open("miniextendr_wrappers.R")
+        .unwrap();
+
+    let mut seen = std::collections::HashSet::<&str>::new();
+    for group in roots {
+        for &s in group {
+            if seen.insert(s) {
+                use std::io::Write;
+                let s = s.trim();
+                let s: String = s
+                    .lines()
+                    .map(|line| line.strip_prefix("    ").unwrap_or(line))
+                    .collect::<Vec<_>>()
+                    .join("\n");
+                f.write_all(s.as_bytes()).unwrap();
+                f.write_all(b"\n\n").unwrap();
+            }
+        }
+    }
+}
diff -ruN a/rpkg/entrypoint.c.in b/rpkg/entrypoint.c.in
--- a/rpkg/entrypoint.c.in	1970-01-01 01:00:00
+++ b/rpkg/entrypoint.c.in	2025-12-23 02:13:36
@@ -0,0 +1,23 @@
+#include <R.h>
+#include <Rinternals.h>
+#include <R_ext/Rdynload.h>
+
+extern void R_init_@PACKAGE_TARNAME_RS@_miniextendr(DllInfo *dll);
+
+// NOTE: miniextendr_encoding_init() is disabled for R packages because it
+// references non-API symbols (utf8locale, etc.) that aren't exported from libR.
+// It only works when embedding R via miniextendr-engine.
+// extern void miniextendr_encoding_init(void);
+extern void miniextendr_panic_hook(void);
+extern void miniextendr_worker_init(void);
+
+void R_init_@PACKAGE_TARNAME_RS@(DllInfo *dll) {
+    miniextendr_panic_hook();
+    miniextendr_worker_init();
+
+    // Main module's R_init calls nonapi's R_init via "use nonapi;" statement
+    R_init_@PACKAGE_TARNAME_RS@_miniextendr(dll);
+
+    R_useDynamicSymbols(dll, FALSE);
+    R_forceSymbols(dll, TRUE);
+}
