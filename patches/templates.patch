diff -ruN -U2 a/monorepo/rpkg/configure.ac b/monorepo/rpkg/configure.ac
--- a/monorepo/rpkg/configure.ac	2026-01-16 02:06:13
+++ b/monorepo/rpkg/configure.ac	2026-01-16 02:07:01
@@ -411,12 +411,30 @@
     STAMP="$VENDOR_OUT/.vendor.lock.cksum"
 
-    dnl Determine if we need to run cargo vendor first
+    dnl Calculate fingerprint of files that affect vendoring
+    dnl Include Cargo.toml.in (dependency changes) and Cargo.lock (if it exists)
+    _fp=""
+    if test -f "src/rust/Cargo.toml.in"; then
+      _fp="$_fp:$(cksum < "src/rust/Cargo.toml.in" | awk '{print [$]1":"[$]2}')"
+    fi
+    if test -f "$LOCKFILE"; then
+      _fp="$_fp:$(cksum < "$LOCKFILE" | awk '{print [$]1":"[$]2}')"
+    fi
+    _old_fp="$(cat "$STAMP" 2>/dev/null || true)"
+
+    dnl Determine if we need to run cargo vendor
     _need_vendor=0
     if test "$FORCE_VENDOR" = "1"; then
       _need_vendor=1
-    elif test ! -f "$VENDOR_OUT/.vendor.lock.cksum"; then
+    elif test ! -f "$STAMP"; then
       _need_vendor=1
     elif test ! -d "$VENDOR_OUT" || test -z "`ls -A \"$VENDOR_OUT\" 2>/dev/null`"; then
       _need_vendor=1
+    elif test "x$_fp" != "x$_old_fp"; then
+      _need_vendor=1
+      echo "configure: dependency files changed, re-vendoring"
+      dnl Remove Cargo.lock to force regeneration with new dependencies
+      if test -f "$LOCKFILE"; then
+        rm -f "$LOCKFILE"
+      fi
     fi
 
@@ -550,9 +568,15 @@
     fi
 
-    dnl POSIX fingerprint: checksum+size of Cargo.lock contents
-    _new="$(cksum < "$LOCKFILE" | awk '{print [$]1":"[$]2}')"
+    dnl Recalculate fingerprint after vendoring (Cargo.lock may have been updated)
+    _fp=""
+    if test -f "src/rust/Cargo.toml.in"; then
+      _fp="$_fp:$(cksum < "src/rust/Cargo.toml.in" | awk '{print [$]1":"[$]2}')"
+    fi
+    if test -f "$LOCKFILE"; then
+      _fp="$_fp:$(cksum < "$LOCKFILE" | awk '{print [$]1":"[$]2}')"
+    fi
 
     dnl Update vendor stamp
-    echo "$_new" > "$STAMP"
+    echo "$_fp" > "$STAMP"
 
     dnl Clear checksums in src/vendor/ for all crates.
