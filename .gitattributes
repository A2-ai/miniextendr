# No LFS tracking — all files stored as regular git blobs

# Force LF line endings for shell scripts and autoconf files.
# Windows git autocrlf converts to CRLF which causes R CMD check warnings:
# "Found the following shell script(s) with CR or CRLF line endings"
configure    eol=lf
configure.ac eol=lf
cleanup      eol=lf
cleanup.ucrt eol=lf
*.sh         eol=lf

# Generated diff — never 3-way merge (produces diff-of-a-diff garbage on rebase).
# On conflict, pick a side and regenerate with `just templates-approve`. See CLAUDE.md.
patches/templates.patch -merge
