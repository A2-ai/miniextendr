#!/bin/sh
# Cleanup script for R package (runs during R CMD build and R CMD INSTALL)
#
# Remove build artifacts and generated files.
# configure recreates Makevars from Makevars.in, so it's safe to delete.

rm -f  src/Makevars
rm -rf src/rust/.cargo
rm -rf src/rust/target
rm -rf rust-target
rm -rf ra-target
rm -f  src/*-wrappers.R

# Remove vendor/ if the compressed tarball exists (CRAN tarball prep).
# Makevars unpacks inst/vendor.tar.xz when needed.
if [ -d "vendor" ] && [ -f "inst/vendor.tar.xz" ]; then
  rm -rf vendor
fi
