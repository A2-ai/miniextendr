#!/bin/sh
# Cleanup script for R package
#
# This script is called during:
# 1. R CMD build (before creating tarball)
# 2. R CMD INSTALL (after compilation)
#
# During R CMD build: Remove vendor/ since inst/vendor.tar.xz contains compressed deps
# During R CMD INSTALL: Delete src/ entirely - the .so is built, nothing else needed
#
# Detection: If the .so exists in libs/, we're post-compilation (R CMD INSTALL).
# R CMD build runs cleanup BEFORE compilation, so no .so exists.
#
# Note: This script runs from the package root directory (where DESCRIPTION is).

# Find the package name from DESCRIPTION
pkg_name=$(grep "^Package:" DESCRIPTION 2>/dev/null | sed 's/Package: *//')

# Check if compiled shared library exists (indicates R CMD INSTALL context)
if [ -f "libs/${pkg_name}.so" ] || [ -f "libs/${pkg_name}.dylib" ] || \
   [ -d "libs" ] && ls libs/*.so libs/*.dylib >/dev/null 2>&1; then
    # ---- R CMD INSTALL (post-compilation cleanup) ----
    # The .so is built. Remove ALL Rust/Cargo/src artifacts.
    rm -rf .cargo
    rm -rf src
    exit 0
fi

# ---- R CMD build (pre-tarball cleanup) ----
# Prepare a clean source tarball for CRAN submission.

# Remove build artifacts
rm -rf .cargo
rm -rf src/.cargo
rm -rf src/rust/target
rm -rf src/rust/.cargo

# Remove generated files (configure recreates them)
rm -f src/Makevars
rm -f src/rust/Cargo.toml
rm -f src/rust/document.rs
rm -f src/entrypoint.c
rm -f src/mx_abi.c
rm -f src/*-wrappers.R

# Remove vendor directory for the tarball (vendor.tar.xz was created by configure)
# This avoids CRAN NOTEs about hidden files and long paths.
# Makevars/configure will unpack inst/vendor.tar.xz when needed.
if [ -d "src/vendor" ] && [ -f "inst/vendor.tar.xz" ]; then
    echo "Removing vendor directory (inst/vendor.tar.xz exists)..."
    rm -rf src/vendor
fi
