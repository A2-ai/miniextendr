configure~
autom4te.cache
config.log
config.status
src/rust/.cargo/config.toml
src/Makevars
# Note: Makevars.win is a static file (uses `include Makevars`), tracked in git
src/*-wrappers.R

# Generated by the host cdylib pass (miniextendr_write_wrappers /
# miniextendr_write_wasm_registry), regenerated byte-deterministically on every
# dev `R CMD INSTALL`. Untracked (like inst/vendor.tar.xz) to avoid constant
# merge conflicts on these large generated files (wrappers.R ~32k lines,
# wasm_registry.rs ~13k lines). They still ship in the tarball from disk
# (.Rbuildignore does NOT exclude them); `just r-cmd-build` regenerates them
# first so the built tarball is complete (wasm-from-tarball has no fallback).
R/*-wrappers.R
src/rust/wasm_registry.rs

# Built artifacts
src/*.o
src/*.so
src/*.dll

# Cargo target directories
# These MUST be outside src/ to avoid pkgbuild scanning generated .rs files
rust-target/
ra-target/
# Legacy locations (inside src/, causes pkgbuild issues)
src/rust/ra_target/
src/rust/target/

# Vendor tarball — generated in CI and at CRAN release time; never tracked.
# Merge conflicts on this binary caused constant PR churn, and every
# in-flight PR that touched a workspace crate had to regen it. CI jobs that
# test CRAN-mode builds run `just vendor` before `R CMD check`.
inst/vendor.tar.xz
inst/.vendor.tar.xz.cksum

# Intermediary files from configure.ac
.vendor-tarball-staging/

# Vendored crates (large, auto-generated by cargo vendor / just vendor)
vendor/
