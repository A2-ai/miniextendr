^LICENSE\.md$
^dev$

# Vendored Makefiles with GNU extensions (not used by R package build)
^src/vendor/r-efi/Makefile$

# Build artifacts and generated files
^src/rust/target$
^src/rust/ra_target$
^src/rust/\.cargo$
^\.cargo$
^src/.*\.o$
^src/.*\.so$
^src/.*\.dll$
^config\.log$
^config\.status$
^configure~$
^autom4te\.cache$

# Generated R wrapper (kept in src/, copied to R/)
^src/miniextendr_wrappers\.R$

# Development files
^bootstrap\.R$
^\.gitignore$
^\.DS_Store$

# R CMD check output
\.Rcheck$

# Vendor compression stamp file (dev-only)
^inst/\.vendor\.tar\.xz\.cksum$

# Vendored crate metadata (causes R CMD check NOTEs/ERRORs)
\.cargo-checksum\.json$
\.cargo_vcs_info\.json$
^src/vendor/.*\.github$
^src/vendor/.*\.editorconfig$
^src/vendor/.*\.git-blame-ignore-revs$
^src/vendor/.*\.release-plz\.toml$
^src/vendor/.*\.rustfmt\.toml$
^src/vendor/.*\.travis\.yml$
\.vendor\.lock\.cksum$

# Static libraries in vendored crates (R CMD check objects NOTE)
^src/vendor/.*\.a$
^src/vendor/.*\.lib$
