NNG_OBJECTS = $(NNG_SOURCES:.c=.o)
MBEDTLS_OBJECTS = $(MBEDTLS_SOURCES:.c=.o)

LIBNNG = nng/libnng.a
LIBMBEDTLS = mbedtls/libmbedtls_all.a

PKG_LIBS = $(CARGO_AR) $(LIBNNG) $(LIBMBEDTLS) $(NNG_LIBS)

## --- pattern rules for subdirectory C compilation ---------------------
## R's default suffix rules don't handle subdirectories; these pattern rules do.
nng/%.o: nng/%.c
	$(CC) $(NNG_CPPFLAGS) $(CPPFLAGS) $(CPICFLAGS) $(CFLAGS) -c $< -o $@

mbedtls/%.o: mbedtls/%.c
	$(CC) $(MBEDTLS_CPPFLAGS) $(CPPFLAGS) $(CPICFLAGS) $(CFLAGS) -c $< -o $@

## --- static archive rules ---------------------------------------------
$(LIBNNG): $(NNG_OBJECTS)
	$(AR) rcs $@ $^

$(LIBMBEDTLS): $(MBEDTLS_OBJECTS)
	$(AR) rcs $@ $^

## ----------------------------------------------------------------------
	@# Dev mode: touch Cargo.toml so pkgbuild always thinks sources changed
	@if [ "$(NOT_CRAN_FLAG)" = "true" ]; then \
	  touch "$(CARGO_TOML)"; \
	fi
	@# CRAN mode: cleanup vendor and target directories to save space
	@# Guard: only clean when inst/vendor.tar.xz exists (genuine CRAN tarball build).
	@# Without this guard, pkgbuild::compile_dll() (called by devtools::document()
	@# and roxygen2::roxygenise()) runs without NOT_CRAN=true and would delete
	@# vendor/ populated by scaffolding, breaking subsequent builds.
	@if [ "$(NOT_CRAN_FLAG)" != "true" ] && [ -f "$(ABS_TOP_SRCDIR)/inst/vendor.tar.xz" ]; then \
	  set -e; \
	  if [ -n "$(VENDOR_OUT)" ] && [ -d "$(VENDOR_OUT)" ]; then rm -rf "$(VENDOR_OUT)"; fi; \
	  if [ -d "$(CARGO_TARGET_DIR)" ]; then rm -rf "$(CARGO_TARGET_DIR)"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/.cargo" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/.cargo"; fi; \
	  if [ -d "$(ABS_TOP_SRCDIR)/rust-target" ]; then rm -rf "$(ABS_TOP_SRCDIR)/rust-target"; fi; \
	  if [ -d "$(ABS_TOP_SRCDIR)/ra-target" ]; then rm -rf "$(ABS_TOP_SRCDIR)/ra-target"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/target" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/target"; fi; \
	  if [ -d "$(ABS_RPKG_SRCDIR)/rust/ra_target" ]; then rm -rf "$(ABS_RPKG_SRCDIR)/rust/ra_target"; fi; \
	fi

# Phony target to force Cargo invocation (no recipe - just triggers dependents)
FORCE_CARGO:

$(SHLIB): $(OBJECTS) $(CARGO_AR) $(LIBNNG) $(LIBMBEDTLS)

# Build the Rust static library
# FORCE_CARGO ensures Cargo is always invoked; Cargo handles incremental builds.
# Note: Dependencies are vendored by configure script, not by this Makefile.
# You must run `./configure` (or `just configure`) before building.
#
# CRAN tarball handling: R CMD build compresses vendor/ into vendor.tar.xz
# to avoid NOTEs about hidden files and long paths. We unpack it here.
VENDOR_TARBALL = $(ABS_TOP_SRCDIR)/inst/vendor.tar.xz

$(CARGO_AR): FORCE_CARGO $(WRAPPERS_R) $(LIBNNG) $(LIBMBEDTLS)
	@# Unpack vendor.tar.xz if vendor/ is missing (CRAN tarball case only)
	@if [ "$(NOT_CRAN_FLAG)" != "true" ] && [ ! -d "$(VENDOR_OUT)" ] && [ -f "$(VENDOR_TARBALL)" ]; then \
	  echo "Unpacking vendor.tar.xz from inst/..."; \
	  cd "$(ABS_TOP_SRCDIR)" && tar -xJf "$(VENDOR_TARBALL)"; \
	fi
	@set -e; \
	TARGET_OPT=""; \
	if [ -n "$(CARGO_BUILD_TARGET)" ]; then TARGET_OPT="--target $(CARGO_BUILD_TARGET)"; fi; \
	RUSTFLAGS="$(ENV_RUSTFLAGS) -C link-arg=$(ABS_RPKG_SRCDIR)/$(LIBNNG) -C link-arg=$(ABS_RPKG_SRCDIR)/$(LIBMBEDTLS)" \
	$(CARGO) $(RUST_TOOLCHAIN) build $(CARGO_OFFLINE_FLAG) $(CARGO_FEATURES_FLAG) $$TARGET_OPT \
	  --lib --profile $(CARGO_PROFILE) \
	  --manifest-path $(CARGO_TOML) \
	  --target-dir $(CARGO_TARGET_DIR); \
	test -f "$(CARGO_AR)"
	@# On Windows, remove cdylib .dll.a import lib so MinGW linker uses the staticlib.
	@rm -f '$(CARGO_LIBDIR)/lib$(CARGO_STATICLIB_NAME).dll.a'

# Automatic R wrapper generation.
# Builds a cdylib (shared library) containing all linkme distributed_slice
# entries, loads it in R, and calls miniextendr_write_wrappers() which
# writes R/*-wrappers.R. The Rust code diffs old vs new and only overwrites
# when content changes (printing a devtools::document() reminder).
# NAMESPACE is NOT generated here — use devtools::document() for that.
$(WRAPPERS_R): $(CARGO_CDYLIB)
	@echo "Generating R wrappers..."
	@_cdylib='$(CARGO_CDYLIB)'; \
	_wrappers='$(WRAPPERS_R)'; \
	if command -v cygpath >/dev/null 2>&1; then \
	  _cdylib=$$(cygpath -m "$$_cdylib"); \
	  _wrappers=$$(cygpath -m "$$_wrappers"); \
	fi; \
	MINIEXTENDR_CDYLIB_WRAPPERS=1 "$(R_HOME)/bin$(R_ARCH)/Rscript" -e "invisible(local({ lib <- dyn.load('$$_cdylib'); .Call(getNativeSymbolInfo('miniextendr_write_wrappers', lib), '$$_wrappers'); dyn.unload('$$_cdylib') }))"
	@echo "Removing cdylib to prevent linker collision with staticlib..."
	@rm -f '$(CARGO_CDYLIB)'

# Build cdylib for wrapper generation (shares incremental compilation with staticlib)
$(CARGO_CDYLIB): FORCE_CARGO $(LIBNNG) $(LIBMBEDTLS)
	@# Unpack vendor.tar.xz if vendor/ is missing (CRAN tarball case only)
	@if [ "$(NOT_CRAN_FLAG)" != "true" ] && [ ! -d "$(VENDOR_OUT)" ] && [ -f "$(VENDOR_TARBALL)" ]; then \
	  echo "Unpacking vendor.tar.xz from inst/..."; \
	  cd "$(ABS_TOP_SRCDIR)" && tar $(TAR_FORCE_LOCAL) -xJf "$(VENDOR_TARBALL)"; \
	fi
	@set -e; \
	TARGET_OPT=""; \
	CDYLIB_LINK_ARGS="-C link-arg=$(ABS_RPKG_SRCDIR)/$(LIBNNG) -C link-arg=$(ABS_RPKG_SRCDIR)/$(LIBMBEDTLS)"; \
	if [ -n "$(CARGO_BUILD_TARGET)" ]; then TARGET_OPT="--target $(CARGO_BUILD_TARGET)"; fi; \
	if [ "$(CDYLIB_EXT)" = "dll" ]; then \
	  CDYLIB_LINK_ARGS="$$CDYLIB_LINK_ARGS -C link-arg=-static-libgcc -C link-arg=$(ABS_RPKG_SRC_CARGO)/cdylib-exports.def -C link-arg=-Wl,--no-gc-sections"; \
	fi; \
	RUSTFLAGS="$(ENV_RUSTFLAGS)" \
	$(CARGO) $(RUST_TOOLCHAIN) rustc $(CARGO_OFFLINE_FLAG) $(CARGO_FEATURES_FLAG) $$TARGET_OPT \
	  --lib --profile $(CARGO_PROFILE) \
	  --manifest-path $(CARGO_TOML) \
	  --target-dir $(CARGO_TARGET_DIR) \
	  --crate-type cdylib \
	  -- $$CDYLIB_LINK_ARGS

clean:
	rm -f $(NNG_OBJECTS) $(MBEDTLS_OBJECTS) $(LIBNNG) $(LIBMBEDTLS)
