[package]
name = "rpkg"
version = "0.1.0"
edition = "2024"
# edition = "2021" # testing 2021 compatibility!
publish = false

[[bin]]
name = "document"
path = "document.rs"
bench = false

[lib]
name = "@CARGO_STATICLIB_NAME@"
path = "lib.rs"
crate-type = ["rlib", "staticlib"]

[profile.release]
debug = 1
panic = "unwind"

[profile.dev]
panic = "unwind"

[dependencies]
miniextendr-api = { path = "@VENDOR_OUT@/miniextendr-api" }
