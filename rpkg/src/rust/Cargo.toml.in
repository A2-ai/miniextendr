[package]
name = "rpkg"
version = "0.1.0"
edition = "2024"
# edition = "2021" # testing 2021 compatibility!
publish = false

# Make this a standalone workspace (prevents inheriting from parent)
[workspace]

[[bin]]
name = "document"
path = "document.rs"
bench = false

[lib]
path = "lib.rs"
crate-type = ["rlib", "staticlib"]

[dependencies]
miniextendr-api = { path = "../../inst/vendor/miniextendr-api" }
