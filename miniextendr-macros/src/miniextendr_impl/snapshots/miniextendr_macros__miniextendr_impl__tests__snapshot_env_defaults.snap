#' @title Widget  Class
#' @name Widget
#' @rdname Widget
#' @source Generated by miniextendr from Rust type `Widget`
#' @export
Widget <- new.env(parent = emptyenv())

# Widget::new (1:1)
#' @name Widget$new
#' @rdname Widget
#' @source Generated by miniextendr from `Widget::new`
Widget$new <- function() {
  .val <- .Call(C_Widget__new, .call = match.call())
  if (inherits(.val, "rust_error_value") && isTRUE(attr(.val, "__rust_error__"))) {
    .msg <- .val$error
    .call <- .val$call %||% sys.call()
    .class <- .val$class
    switch(.val$kind,
      error = stop(structure(list(message = .msg, call = .call),class = c(.class, "rust_error", "simpleError", "error", "condition"))),
      warning = { warning(structure(list(message = .msg, call = .call),class = c(.class, "rust_warning", "simpleWarning", "warning", "condition"))); return(invisible(NULL)) },
      message = { message(structure(list(message = paste0(.msg, "\n"), call = NULL),class = c(.class, "rust_message", "simpleMessage", "message", "condition"))); return(invisible(NULL)) },
      condition = { signalCondition(structure(list(message = .msg, call = .call),class = c(.class, "rust_condition", "simpleCondition", "condition"))); return(invisible(NULL)) },
      panic = stop(structure(list(message = .msg, call = .call),class = c("rust_error", "simpleError", "error", "condition"))),
      stop(structure(list(message = .msg, call = .call),
        class = c("rust_error", "simpleError", "error", "condition")))
    )
  }
  self <- .val
  class(self) <- "Widget"
  self
}

# Widget::update (1:1)
#' @name Widget$update
#' @rdname Widget
#' @source Generated by miniextendr from `Widget::update`
Widget$update <- function(step = 1L, verbose = FALSE) {
  stopifnot(
    "'step' must be numeric, logical, or raw" = is.numeric(step) || is.logical(step) || is.raw(step),
    "'step' must have length 1" = length(step) == 1L,
    "'verbose' must be logical" = is.logical(verbose),
    "'verbose' must have length 1" = length(verbose) == 1L
  )
  .val <- .Call(C_Widget__update, .call = match.call(), self, step, verbose)
  if (inherits(.val, "rust_error_value") && isTRUE(attr(.val, "__rust_error__"))) {
    .msg <- .val$error
    .call <- .val$call %||% sys.call()
    .class <- .val$class
    switch(.val$kind,
      error = stop(structure(list(message = .msg, call = .call),class = c(.class, "rust_error", "simpleError", "error", "condition"))),
      warning = { warning(structure(list(message = .msg, call = .call),class = c(.class, "rust_warning", "simpleWarning", "warning", "condition"))); return(invisible(NULL)) },
      message = { message(structure(list(message = paste0(.msg, "\n"), call = NULL),class = c(.class, "rust_message", "simpleMessage", "message", "condition"))); return(invisible(NULL)) },
      condition = { signalCondition(structure(list(message = .msg, call = .call),class = c(.class, "rust_condition", "simpleCondition", "condition"))); return(invisible(NULL)) },
      panic = stop(structure(list(message = .msg, call = .call),class = c("rust_error", "simpleError", "error", "condition"))),
      stop(structure(list(message = .msg, call = .call),
        class = c("rust_error", "simpleError", "error", "condition")))
    )
  }
  self
}

#' @rdname Widget
#' @param self The object instance.
#' @param name Method name for dispatch.
#' @export
`$.Widget` <- function(self, name) {
  obj <- Widget[[name]]
  if (is.environment(obj)) {
    # Trait namespace - wrap instance methods to prepend self
    bound <- new.env(parent = emptyenv())
    for (method_name in names(obj)) {
      method <- obj[[method_name]]
      if (is.function(method)) {
        if (isTRUE(attr(method, ".__mx_instance__"))) {
          local({
            m <- method
            bound[[method_name]] <<- function(...) m(self, ...)
          })
        } else {
          bound[[method_name]] <- method
        }
      }
    }
    bound
  } else if (is.null(obj)) {
    # Not found at top level -- search trait namespace environments
    for (ns_name in names(Widget)) {
      ns <- Widget[[ns_name]]
      if (is.environment(ns) && exists(name, envir = ns, inherits = FALSE)) {
        method <- ns[[name]]
        if (is.function(method) && isTRUE(attr(method, ".__mx_instance__"))) {
          # Instance method -- bind self as first arg
          m <- method
          s <- self
          return(function(...) m(s, ...))
        } else if (is.function(method)) {
          return(method)
        }
      }
    }
    NULL
  } else {
    environment(obj) <- environment()
    obj
  }
}
#' @rdname Widget
#' @export
`[[.Widget` <- `$.Widget`
