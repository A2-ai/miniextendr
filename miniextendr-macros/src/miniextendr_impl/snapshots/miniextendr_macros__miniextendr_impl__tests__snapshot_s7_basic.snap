#' @title Counter S7 Class
#' @name Counter
#' @rdname Counter
#' @source Generated by miniextendr from Rust type `Counter`
#' @importFrom S7 new_class class_any new_object S7_object new_generic method
#' @export
#' @param value (undocumented)
#' @param .ptr Internal pointer (used by static methods, not for direct use).
Counter <- S7::new_class("Counter",
  properties = list(
    .ptr = S7::class_any
  ),
  constructor = function(value, .ptr = NULL) {
    if (is.null(.ptr)) {
      stopifnot(
        "'value' must be numeric, logical, or raw" = is.numeric(value) || is.logical(value) || is.raw(value),
        "'value' must have length 1" = length(value) == 1L
      )
    }
    if (!is.null(.ptr)) {
      S7::new_object(S7::S7_object(), .ptr = .ptr)
    } else {
      .val <- .Call(C_Counter__new, .call = match.call(), value)
      if (inherits(.val, "rust_condition_value") && isTRUE(attr(.val, "__rust_condition__"))) return(.miniextendr_raise_condition(.val, sys.call()))
      S7::new_object(S7::S7_object(), .ptr = .val)
    }
  }
)

