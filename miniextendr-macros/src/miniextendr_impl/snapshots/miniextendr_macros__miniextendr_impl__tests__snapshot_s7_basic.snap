#' @title Counter S7 Class
#' @name Counter
#' @rdname Counter
#' @source Generated by miniextendr from Rust type `Counter`
#' @importFrom S7 new_class class_any new_object S7_object new_generic method
#' @export
#' @param .ptr Internal pointer (used by static methods, not for direct use).
Counter <- S7::new_class("Counter",
  properties = list(
    .ptr = S7::class_any
  ),
  constructor = function(value, .ptr = NULL) {
    if (is.null(.ptr)) {
      stopifnot(
        "'value' must be numeric, logical, or raw" = is.numeric(value) || is.logical(value) || is.raw(value),
        "'value' must have length 1" = length(value) == 1L
      )
    }
    if (!is.null(.ptr)) {
      S7::new_object(S7::S7_object(), .ptr = .ptr)
    } else {
      S7::new_object(S7::S7_object(), .ptr = .Call(C_Counter__new, .call = match.call(), value))
    }
  }
)

#' @name get
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::get`
#' @export
if (!exists("get", mode = "function")) {
  get <- S7::new_generic("get", "x", function(x, ...) S7::S7_dispatch())
}
S7::method(get, Counter) <- function(x, ...) .Call(C_Counter__get, .call = match.call(), x@.ptr)

#' @name increment
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::increment`
#' @export
if (!exists("increment", mode = "function")) {
  increment <- S7::new_generic("increment", "x", function(x, ...) S7::S7_dispatch())
}
S7::method(increment, Counter) <- function(x, ...) { .Call(C_Counter__increment, .call = match.call(), x@.ptr); x }

#' @name Counter_from_parts
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::from_parts`
#' @export
Counter_from_parts <- function(a, b) {
  stopifnot(
    "'a' must be numeric, logical, or raw" = is.numeric(a) || is.logical(a) || is.raw(a),
    "'a' must have length 1" = length(a) == 1L,
    "'b' must be numeric, logical, or raw" = is.numeric(b) || is.logical(b) || is.raw(b),
    "'b' must have length 1" = length(b) == 1L
  )
  Counter(.ptr = .Call(C_Counter__from_parts, .call = match.call(), a, b))
}
