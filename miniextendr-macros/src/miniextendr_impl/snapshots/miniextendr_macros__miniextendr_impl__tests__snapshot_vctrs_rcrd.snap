#' @title Rational vctrs S3 Class
#' @name Rational
#' @rdname Rational
#' @source Generated by miniextendr from Rust type `Rational`
#' @importFrom vctrs new_vctr new_rcrd new_list_of vec_ptype2 vec_cast vec_ptype_abbr
#' @export
new_rational <- function(n, d) {
  data <- .Call(C_Rational__new, .call = match.call(), n, d)
  vctrs::new_rcrd(data, class = "Rational")
}

#' @rdname Rational
#' @method vec_ptype_abbr Rational
#' @export
vec_ptype_abbr.Rational <- function(x, ...) "rat"

#' @rdname Rational
#' @method vec_ptype2 Rational.Rational
#' @param x A Rational vector.
#' @param y A Rational vector.
#' @param ... Additional arguments (unused).
#' @export
vec_ptype2.Rational.Rational <- function(x, y, ...) x[0]

#' @rdname Rational
#' @method vec_cast Rational.Rational
#' @param x A Rational vector to cast.
#' @param to A Rational prototype.
#' @param ... Additional arguments (unused).
#' @export
vec_cast.Rational.Rational <- function(x, to, ...) x

#' @title S3 generic for `numerator`
#' S3 generic for `numerator`
#' @rdname Rational
#' @name numerator
#' @param x An object
#' @param ... Additional arguments passed to methods
#' @source Generated by miniextendr from `Rational::numerator`
#' @export
if (!exists("numerator", mode = "function")) {
  numerator <- function(x, ...) UseMethod("numerator")
}

#' @name numerator
#' @rdname Rational
#' @source Generated by miniextendr from `Rational::numerator`
#' @method numerator Rational
numerator.Rational <- function(x, ...) {
  .Call(C_Rational__numerator, .call = match.call(), x)
}
