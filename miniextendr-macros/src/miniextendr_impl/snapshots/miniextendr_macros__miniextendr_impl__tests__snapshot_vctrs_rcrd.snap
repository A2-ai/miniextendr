# Rational::new (1:1)
#' @title Rational vctrs S3 Class
#' @name Rational
#' @rdname Rational
#' @source Generated by miniextendr from Rust type `Rational`
#' @importFrom vctrs new_vctr new_rcrd new_list_of vec_ptype2 vec_cast vec_ptype_abbr
#' @export
new_rational <- function(n, d) {
  stopifnot(
    "'n' must be numeric, logical, or raw" = is.numeric(n) || is.logical(n) || is.raw(n),
    "'n' must have length 1" = length(n) == 1L,
    "'d' must be numeric, logical, or raw" = is.numeric(d) || is.logical(d) || is.raw(d),
    "'d' must have length 1" = length(d) == 1L
  )
  .val <- .Call(C_Rational__new, .call = match.call(), n, d)
  if (inherits(.val, "rust_condition_value") && isTRUE(attr(.val, "__rust_condition__"))) return(.miniextendr_raise_condition(.val, sys.call()))
  data <- .val
  vctrs::new_rcrd(data, class = "Rational")
}

#' @rdname Rational
#' @method vec_ptype_abbr Rational
#' @export
vec_ptype_abbr.Rational <- function(x, ...) "rat"

#' @rdname Rational
#' @method vec_ptype2 Rational.Rational
#' @param x A Rational vector.
#' @param y A Rational vector.
#' @param ... Additional arguments (unused).
