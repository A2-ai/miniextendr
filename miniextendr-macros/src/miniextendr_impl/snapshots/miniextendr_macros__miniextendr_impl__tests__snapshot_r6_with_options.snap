#' @title Child R6 Class
#' @name Child
#' @rdname Child
#' @source Generated by miniextendr from Rust type `Child`
#' @importFrom R6 R6Class
#' @param .ptr Internal pointer (used by static methods, not for direct use).
#' @export
Child <- R6::R6Class("Child", inherit = ParentClass,
  public = list(
    initialize = function(.ptr = NULL) {
      if (!is.null(.ptr)) {
        private$.ptr <- .ptr
      } else {
        .val <- .Call(C_Child__new, .call = match.call())
        if (inherits(.val, "rust_error_value") && isTRUE(attr(.val, "__rust_error__"))) {
          stop(structure(
            class = c("rust_error", "simpleError", "error", "condition"),
            list(message = .val$error, call = .val$call %||% sys.call(), kind = .val$kind)
          ))
        }
        private$.ptr <- .val
      }
    },
    greet = function() {
      .val <- .Call(C_Child__greet, .call = match.call(), private$.ptr)
      if (inherits(.val, "rust_error_value") && isTRUE(attr(.val, "__rust_error__"))) {
        stop(structure(
          class = c("rust_error", "simpleError", "error", "condition"),
          list(message = .val$error, call = .val$call %||% sys.call(), kind = .val$kind)
        ))
      }
      .val
    }
  ),
  private = list(
    .ptr = NULL
  ),
  lock_objects = TRUE,
  lock_class = TRUE,
  cloneable = TRUE
)
