#' @title Counter S3 Class
#' @name Counter
#' @rdname Counter
#' @source Generated by miniextendr from Rust type `Counter`
#' @export
new_counter <- function(value) {
  stopifnot(
    "'value' must be numeric, logical, or raw" = is.numeric(value) || is.logical(value) || is.raw(value),
    "'value' must have length 1" = length(value) == 1L
  )
  structure(.Call(C_Counter__new, .call = match.call(), value), class = "Counter")
}

#' @title S3 generic for `get`
#' S3 generic for `get`
#' @rdname Counter
#' @name get
#' @param x An object
#' @param ... Additional arguments passed to methods
#' @source Generated by miniextendr from `Counter::get`
#' @export
if (!exists("get", mode = "function")) {
  get <- function(x, ...) UseMethod("get")
}

#' @name get
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::get`
#' @method get Counter
#' @export
get.Counter <- function(x, ...) {
  .Call(C_Counter__get, .call = match.call(), x)
}

#' @title S3 generic for `increment`
#' S3 generic for `increment`
#' @rdname Counter
#' @name increment
#' @param x An object
#' @param ... Additional arguments passed to methods
#' @source Generated by miniextendr from `Counter::increment`
#' @export
if (!exists("increment", mode = "function")) {
  increment <- function(x, ...) UseMethod("increment")
}

#' @name increment
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::increment`
#' @method increment Counter
#' @export
increment.Counter <- function(x, ...) {
  .Call(C_Counter__increment, .call = match.call(), x)
  x
}

#' @name counter_zero
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::zero`
#' @export
counter_zero <- function() {
  structure(.Call(C_Counter__zero, .call = match.call()), class = "Counter")
}

#' @rdname Counter
#' @export
Counter <- new.env(parent = emptyenv())

Counter$new <- new_counter
