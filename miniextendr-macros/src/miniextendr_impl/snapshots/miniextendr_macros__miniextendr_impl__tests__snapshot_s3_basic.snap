# Counter::new (1:1)
#' @title Counter S3 Class
#' @name Counter
#' @rdname Counter
#' @source Generated by miniextendr from Rust type `Counter`
#' @export
new_counter <- function(value) {
  stopifnot(
    "'value' must be numeric, logical, or raw" = is.numeric(value) || is.logical(value) || is.raw(value),
    "'value' must have length 1" = length(value) == 1L
  )
  .val <- .Call(C_miniextendr_macros_Counter__new, .call = match.call(), value)
  if (inherits(.val, "rust_condition_value") && isTRUE(attr(.val, "__rust_condition__"))) return(.miniextendr_raise_condition(.val, sys.call()))
  structure(.val, class = "Counter")
}

# Counter::get (1:1)
#' @title S3 generic for `get`
#' @description S3 generic for `get`
#' @name get.Counter
#' @rdname Counter
#' @param x An object
#' @param ... Additional arguments passed to methods
#' @source Generated by miniextendr from `Counter::get`
#' @export get
if (!base::exists("get", mode = "function")) {
  get <- function(x, ...) UseMethod("get")
} else if (local({ .mx_gen <- base::get("get", mode = "function"); !(is.primitive(.mx_gen) || isTRUE(utils::isS3stdGeneric(.mx_gen)) || methods::isGeneric("get") || inherits(.mx_gen, "S7_generic")) })) {
  # `get` is a plain closure that UseMethod dispatch will never consult.
  # Shadow it with a package-local generic. The default method delegating to
  # the masked closure is registered via registerS3method() so it lives ONLY
  # in the namespace's S3 methods table: a literal `get.default` binding
  # would trip roxygen2's dynamic S3 scan (warn_missing_s3_exports), and a
  # static NAMESPACE S3method(get, default) would break package load
  # whenever this branch does not fire.
  .mx_shadow_default <- local({
    .mx_masked <- base::get("get", mode = "function")
    function(x, ...) .mx_masked(x, ...)
  })
  get <- function(x, ...) UseMethod("get")
  base::registerS3method("get", "default", .mx_shadow_default, envir = base::environment())
  base::rm(.mx_shadow_default)
}
# else: existing usable generic (primitive/S3/S4/S7) — reuse as-is.

