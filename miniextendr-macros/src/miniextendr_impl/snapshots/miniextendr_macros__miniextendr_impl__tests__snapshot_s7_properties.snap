#' @title Range S7 Class
#' @name Range
#' @rdname Range
#' @source Generated by miniextendr from Rust type `Range`
#' @importFrom S7 new_class class_any new_object S7_object new_generic method new_property class_double
#' @export
#' @param start (undocumented)
#' @param end (undocumented)
#' @param .ptr Internal pointer (used by static methods, not for direct use).
Range <- S7::new_class("Range",
  properties = list(
    .ptr = S7::class_any,
    length = S7::new_property(class = S7::class_double, getter = function(self) .Call(C_Range__length, .call = NULL, self@.ptr)),
    midpoint = S7::new_property(class = S7::class_double, getter = function(self) .Call(C_Range__get_midpoint, .call = NULL, self@.ptr), setter = function(self, value) { .Call(C_Range__set_midpoint, .call = NULL, self@.ptr, value); self })
  ),
  constructor = function(start, end, .ptr = NULL) {
    if (is.null(.ptr)) {
      stopifnot(
        "'start' must be numeric, logical, or raw" = is.numeric(start) || is.logical(start) || is.raw(start),
        "'start' must have length 1" = length(start) == 1L,
        "'end' must be numeric, logical, or raw" = is.numeric(end) || is.logical(end) || is.raw(end),
        "'end' must have length 1" = length(end) == 1L
      )
    }
    if (!is.null(.ptr)) {
      S7::new_object(S7::S7_object(), .ptr = .ptr)
    } else {
      .val <- .Call(C_Range__new, .call = match.call(), start, end)
      if (inherits(.val, "rust_error_value") && isTRUE(attr(.val, "__rust_error__"))) {
        .msg <- .val$error
        .call <- .val$call %||% sys.call()
        .class <- .val$class
        switch(.val$kind,
          error = stop(structure(list(message = .msg, call = .call),class = c(.class, "rust_error", "simpleError", "error", "condition"))),
          warning = { warning(structure(list(message = .msg, call = .call),class = c(.class, "rust_warning", "simpleWarning", "warning", "condition"))); return(invisible(NULL)) },
          message = { message(structure(list(message = paste0(.msg, "\n"), call = NULL),class = c(.class, "rust_message", "simpleMessage", "message", "condition"))); return(invisible(NULL)) },
          condition = { signalCondition(structure(list(message = .msg, call = .call),class = c(.class, "rust_condition", "simpleCondition", "condition"))); return(invisible(NULL)) },
          panic = stop(structure(list(message = .msg, call = .call),class = c("rust_error", "simpleError", "error", "condition"))),
          stop(structure(list(message = .msg, call = .call),
            class = c("rust_error", "simpleError", "error", "condition")))
        )
      }
      S7::new_object(S7::S7_object(), .ptr = .val)
    }
  }
)
