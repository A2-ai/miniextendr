#' @title Counter  Class
#' @name Counter
#' @rdname Counter
#' @source Generated by miniextendr from Rust type `Counter`
#' @export
Counter <- new.env(parent = emptyenv())

#' @title Create a new counter
#'
#' \describe{
#'   \item{\code{value}}{Initial value}
#' }
#' @name Counter$new
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::new`
Counter$new <- function(value) {
  self <- .Call(C_Counter__new, .call = match.call(), value)
  class(self) <- "Counter"
  self
}

#' @description Get the current value
#' @name Counter$get
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::get`
Counter$get <- function() {
  .Call(C_Counter__get, .call = match.call(), self)
}

#' @description Increment by one
#' @name Counter$increment
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::increment`
Counter$increment <- function() {
  .Call(C_Counter__increment, .call = match.call(), self)
  self
}

#' @description Add a value and return the result
#' @name Counter$add
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::add`
Counter$add <- function(n) {
  .Call(C_Counter__add, .call = match.call(), self, n)
}

#' @description Create from string
#' @name Counter$from_string
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::from_string`
Counter$from_string <- function(s) {
  result <- .Call(C_Counter__from_string, .call = match.call(), s)
  class(result) <- "Counter"
  result
}

#' @rdname Counter
#' @param self The object instance.
#' @param name Method name for dispatch.
#' @export
`$.Counter` <- function(self, name) {
  obj <- Counter[[name]]
  if (is.environment(obj)) {
    # Trait namespace - wrap instance methods to prepend self
    bound <- new.env(parent = emptyenv())
    for (method_name in names(obj)) {
      method <- obj[[method_name]]
      if (is.function(method)) {
        if (isTRUE(attr(method, ".__mx_instance__"))) {
          local({
            m <- method
            bound[[method_name]] <<- function(...) m(self, ...)
          })
        } else {
          bound[[method_name]] <- method
        }
      }
    }
    bound
  } else if (is.null(obj)) {
    # Not found at top level — search trait namespace environments
    for (ns_name in names(Counter)) {
      ns <- Counter[[ns_name]]
      if (is.environment(ns) && exists(name, envir = ns, inherits = FALSE)) {
        method <- ns[[name]]
        if (is.function(method) && isTRUE(attr(method, ".__mx_instance__"))) {
          # Instance method — bind self as first arg
          m <- method
          s <- self
          return(function(...) m(s, ...))
        } else if (is.function(method)) {
          return(method)
        }
      }
    }
    NULL
  } else {
    environment(obj) <- environment()
    obj
  }
}
#' @rdname Counter
#' @export
`[[.Counter` <- `$.Counter`
