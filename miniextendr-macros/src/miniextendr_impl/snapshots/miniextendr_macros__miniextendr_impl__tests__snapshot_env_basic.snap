# Counter::from_string (1:1)
#' @description Create from string
#' @name Counter$from_string
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::from_string`
Counter$from_string <- function(s) {
  stopifnot(
    "'s' must be character" = is.character(s),
    "'s' must have length 1" = length(s) == 1L
  )
  .val <- .Call(C_Counter__from_string, .call = match.call(), s)
  if (inherits(.val, "rust_condition_value") && isTRUE(attr(.val, "__rust_condition__"))) return(.miniextendr_raise_condition(.val, sys.call()))
  class(.val) <- "Counter"
  .val
}

#' @rdname Counter
#' @param self The object instance.
#' @param name Method name for dispatch.
#' @export
`$.Counter` <- function(self, name) {
  obj <- Counter[[name]]
  if (is.environment(obj)) {
    # Trait namespace - wrap instance methods to prepend self
    bound <- new.env(parent = emptyenv())
    for (method_name in names(obj)) {
      method <- obj[[method_name]]
      if (is.function(method)) {
        if (isTRUE(attr(method, ".__mx_instance__"))) {
          local({
            m <- method
            bound[[method_name]] <<- function(...) m(self, ...)
          })
        } else {
          bound[[method_name]] <- method
        }
      }
    }
    bound
  } else if (is.null(obj)) {
    # Not found at top level -- search trait namespace environments
    for (ns_name in names(Counter)) {
      ns <- Counter[[ns_name]]
      if (is.environment(ns) && exists(name, envir = ns, inherits = FALSE)) {
        method <- ns[[name]]
        if (is.function(method) && isTRUE(attr(method, ".__mx_instance__"))) {
          # Instance method -- bind self as first arg
          m <- method
          s <- self
          return(function(...) m(s, ...))
        } else if (is.function(method)) {
          return(method)
        }
      }
    }
    NULL
  } else {
    environment(obj) <- environment()
    obj
  }
}
#' @rdname Counter
#' @export
`[[.Counter` <- `$.Counter`
