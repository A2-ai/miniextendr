#' @title Percent vctrs S3 Class
#' @name Percent
#' @rdname Percent
#' @source Generated by miniextendr from Rust type `Percent`
#' @importFrom vctrs new_vctr new_rcrd new_list_of vec_ptype2 vec_cast vec_ptype_abbr
#' @export
new_percent <- function(x) {
  stopifnot(
    "'x' must be numeric, logical, or raw" = is.numeric(x) || is.logical(x) || is.raw(x),
    "'x' must have length 1" = length(x) == 1L
  )
  data <- .Call(C_Percent__new, .call = match.call(), x)
  vctrs::new_vctr(data, class = "Percent", inherit_base_type = FALSE)
}

#' @rdname Percent
#' @method vec_ptype_abbr Percent
#' @export
vec_ptype_abbr.Percent <- function(x, ...) "pct"

#' @rdname Percent
#' @method vec_ptype2 Percent.Percent
#' @param x A Percent vector.
#' @param y A Percent vector.
#' @param ... Additional arguments (unused).
#' @export
vec_ptype2.Percent.Percent <- function(x, y, ...) vctrs::new_vctr(double(), class = "Percent", inherit_base_type = FALSE)

#' @rdname Percent
#' @method vec_cast Percent.Percent
#' @param x A Percent vector to cast.
#' @param to A Percent prototype.
#' @param ... Additional arguments (unused).
#' @export
vec_cast.Percent.Percent <- function(x, to, ...) x

#' @title S3 generic for `value`
#' S3 generic for `value`
#' @rdname Percent
#' @name value
#' @param x An object
#' @param ... Additional arguments passed to methods
#' @source Generated by miniextendr from `Percent::value`
#' @export
if (!exists("value", mode = "function")) {
  value <- function(x, ...) UseMethod("value")
}

#' @name value
#' @rdname Percent
#' @source Generated by miniextendr from `Percent::value`
#' @method value Percent
value.Percent <- function(x, ...) {
  .Call(C_Percent__value, .call = match.call(), x)
}

#' @title S3 generic for `scale`
#' S3 generic for `scale`
#' @rdname Percent
#' @name scale
#' @param x An object
#' @param ... Additional arguments passed to methods
#' @source Generated by miniextendr from `Percent::scale`
#' @export
if (!exists("scale", mode = "function")) {
  scale <- function(x, ...) UseMethod("scale")
}

#' @name scale
#' @rdname Percent
#' @source Generated by miniextendr from `Percent::scale`
#' @method scale Percent
scale.Percent <- function(x, factor, ...) {
  stopifnot(
    "'factor' must be numeric, logical, or raw" = is.numeric(factor) || is.logical(factor) || is.raw(factor),
    "'factor' must have length 1" = length(factor) == 1L
  )
  .Call(C_Percent__scale, .call = match.call(), x, factor)
  x
}
