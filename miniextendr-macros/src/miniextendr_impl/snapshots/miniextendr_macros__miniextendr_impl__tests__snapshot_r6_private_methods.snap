#' @title Secure R6 Class
#' @name Secure
#' @rdname Secure
#' @source Generated by miniextendr from Rust type `Secure`
#' @importFrom R6 R6Class
#' @param .ptr Internal pointer (used by static methods, not for direct use).
#' @export
Secure <- R6::R6Class("Secure",
  public = list(
    initialize = function(.ptr = NULL) {
      if (!is.null(.ptr)) {
        private$.ptr <- .ptr
      } else {
        private$.ptr <- .Call(C_Secure__new, .call = match.call())
      }
    },
    public_api = function() {
      .Call(C_Secure__public_api, .call = match.call(), private$.ptr)
    }
  ),
  private = list(
    internal_compute = function() {
      .Call(C_Secure__internal_compute, .call = match.call(), private$.ptr)
    },
    .ptr = NULL
  ),
  lock_objects = TRUE,
  lock_class = FALSE,
  cloneable = FALSE
)
