#' @title Counter R6 Class
#' @name Counter
#' @rdname Counter
#' @source Generated by miniextendr from Rust type `Counter`
#' @importFrom R6 R6Class
#' @param .ptr Internal pointer (used by static methods, not for direct use).
#' @export
Counter <- R6::R6Class("Counter",
  public = list(
    #' @description Create a new counter
    #' @param value Initial value
    initialize = function(value, .ptr = NULL) {
      if (!is.null(.ptr)) {
        private$.ptr <- .ptr
      } else {
        private$.ptr <- .Call(C_Counter__new, .call = match.call(), value)
      }
    },
    #' @description Get the current value
    get = function() {
      .Call(C_Counter__get, .call = match.call(), private$.ptr)
    },
    #' @description Increment by one
    increment = function() {
      .Call(C_Counter__increment, .call = match.call(), private$.ptr)
      invisible(self)
    }
  ),
  private = list(
    .ptr = NULL
  ),
  lock_objects = TRUE,
  lock_class = FALSE,
  cloneable = FALSE
)

#' @description Create from value (static factory)
#' @name Counter$from_value
#' @rdname Counter
#' @source Generated by miniextendr from `Counter::from_value`
Counter$from_value <- function(v) {
