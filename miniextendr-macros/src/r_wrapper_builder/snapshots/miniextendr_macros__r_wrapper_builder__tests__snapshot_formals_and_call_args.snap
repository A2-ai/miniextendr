---
source: miniextendr-macros/src/r_wrapper_builder/tests.rs
assertion_line: 395
expression: output
---
# Basic scalars
formals: x, y, name
call_args: x, y, name

# Unit type default
formals: x, unused = NULL
call_args: x, unused

# With dots
formals: x, ...
call_args: x, list(...)

# Skip first (method)
formals: x, y
call_args: x, y

# User defaults
formals: x, step = 1L, verbose = FALSE
call_args: x, step, verbose

# Missing<T> clean formals
formals: x, y, z
call_args: x, if (missing(y)) quote(expr=) else y, if (missing(z)) quote(expr=) else z
