# macOS
.DS_Store

# IDE
.Rproj.*

# generated by rpkg.configure via cargo-config.toml.in
.cargo/config.toml
rpkg/src/Makevars
rpkg/src/rust/Cargo.toml
rpkg/src/rust/.cargo/

# Cargo build artifacts (workspaces in repo root and subdirectories)
target/
# Per-package CARGO_TARGET_DIR set by rpkg/configure.ac (lives outside the
# package source tree so R CMD check's compiled-code phase doesn't scan it).
rust-target-*/

# R package build artifacts
*.Rcheck/
*.tar.gz

# R CMD INSTALL library location
dev_lib/

# Reference documentation (not part of project)
background/

# devtools::check output directory
rpkg-check-output/
dvs_reviews/

# Zola site build output
site/public/

# Agent worktrees
.claude/worktrees/
.claude/scheduled_tasks.lock
