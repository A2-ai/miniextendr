# macOS
.DS_Store

# IDE
.Rproj.*

# generated by rpkg.configure via cargo-config.toml.in
.cargo/config.toml
rpkg/src/Makevars
rpkg/src/rust/Cargo.toml
rpkg/src/rust/.cargo/

# Cargo build artifacts (workspaces in repo root and subdirectories)
target/

# R package build artifacts
*.Rcheck/
*.tar.gz

# R CMD INSTALL library location
dev_lib/

# Reference documentation (not part of project)
background/

# devtools::check output directory
rpkg-check-output/
dvs_reviews/

# Zola site build output
site/public/

# Auto-generated by scripts/docs-to-site.sh from docs/ — regenerated in CI.
# Keep _index.md (hand-written landing copy).
site/content/manual/*.md
!site/content/manual/_index.md

# Agent worktrees
.claude/worktrees/
.claude/scheduled_tasks.lock
