#!/bin/bash
# miniextendr pre-commit hook
# Asserts rpkg/src/rust/Cargo.lock stays in tarball-shape.
#
# Install (once per clone):
#   git config core.hooksPath .githooks
#
# NOTE: the former "*-wrappers.R staged without NAMESPACE" check was removed when
# R/*-wrappers.R and src/rust/wasm_registry.rs became gitignored (regenerated on
# every install, never committed). They can no longer be staged, so the check was
# dead. NAMESPACE / man drift from #[miniextendr] source is caught by CI's
# `just wrappers-sync-check` instead.

set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED" ]; then
    exit 0
fi

# ‚îÄ‚îÄ Cargo.lock tarball-shape assertion ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# rpkg/src/rust/Cargo.lock must stay in "tarball-shape":
# - miniextendr-{api,lint,macros} have source = "git+https://github.com/A2-ai/miniextendr#‚Ä¶"
# - no [[patch.unused]] blocks
# checksum = "..." lines are ALLOWED: cargo-revendor writes valid
# .cargo-checksum.json files whose `package` field matches them.
#
# Two drift modes both break CRAN/tarball builds:
#   1. `cargo build` under `[patch.crates-io]` path overrides ‚Üí "path+‚Ä¶" sources
#   2. `cargo ‚Ä¶  --config "patch.'‚Ä¶'.path=‚Ä¶"` (just check/clippy/build/test) ‚Üí
#      `source` line STRIPPED entirely
# We inspect the staged blob (not the diff) so the assertion is structural and
# doesn't depend on whether the lockfile's prior shape was already broken.
#
# NOTE (#680): the earlier diff-based form ‚Äî
#   lock_content=$(git diff --cached ‚Ä¶ | grep '^+' | grep -v '^+++')
# ‚Äî exited the whole hook *silently* under `set -euo pipefail` when the staged
# diff had only deletions (cargo stripped the `source = "git+‚Ä¶"` lines): the
# leading `grep '^+'` found nothing, returned 1, pipefail propagated it, and the
# command-substitution aborted the script with no message. The staged-blob form
# below is immune: every grep here is either the condition of an `if`/`if !`
# (where `set -e`/pipefail are suppressed for the tested pipeline) or guarded
# with `|| true`. Keep it that way ‚Äî never re-introduce a bare grep pipeline in
# a command-substitution under pipefail.
staged_lock=$(echo "$STAGED" | grep -F 'rpkg/src/rust/Cargo.lock' || true)
if [ -n "$staged_lock" ]; then
    # The lockfile is staged ACM (line 10 filters out deletions), so the index
    # blob always exists; guard with `|| true` anyway so a future filter change
    # can't turn a `git show` failure into a silent `set -e` abort.
    staged_blob=$(git show ":rpkg/src/rust/Cargo.lock" || true)
    for crate in miniextendr-api miniextendr-lint miniextendr-macros; do
        if ! echo "$staged_blob" | grep -A 3 "^name = \"$crate\"\$" \
                | grep -q '^source = "git+https://github\.com/A2-ai/miniextendr'; then
            echo "pre-commit: rpkg/src/rust/Cargo.lock ‚Äî $crate is missing the canonical" >&2
            echo "  source = \"git+https://github.com/A2-ai/miniextendr#<sha>\" line." >&2
            echo "  This commit would strip the git+url sources the tarball build needs." >&2
            echo "  Likely cause: local 'just check / clippy / build / test' stripped it" >&2
            echo "  under '--config \"patch.'‚Ä¶'.path=‚Ä¶\"'." >&2
            echo "  Restore the canonical shape, then re-stage Cargo.lock:" >&2
            echo "    just cargo-lock-restore                        # restore from HEAD" >&2
            echo "    git checkout -- rpkg/src/rust/Cargo.lock       # discard the staged change" >&2
            echo "    just vendor                                    # regenerate canonical shape" >&2
            exit 1
        fi
    done
    if echo "$staged_blob" | grep -qE '^\[\[patch\.unused\]\]'; then
        echo "pre-commit: rpkg/src/rust/Cargo.lock has [[patch.unused]] blocks." >&2
        echo "  Narrow the [patch.crates-io] override in .cargo/config.toml." >&2
        echo "  Run: just vendor    # regenerates canonical shape" >&2
        exit 1
    fi
fi

exit 0
