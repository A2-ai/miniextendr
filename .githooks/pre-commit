#!/bin/bash
# miniextendr pre-commit hook
# Blocks commits where *-wrappers.R is staged without a matching NAMESPACE update.
#
# Install (once per clone):
#   git config core.hooksPath .githooks

set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED" ]; then
    exit 0
fi

# ── Stale NAMESPACE (wrappers changed without devtools::document()) ──────────
# R/*-wrappers.R is auto-generated by the Rust build. After it changes,
# devtools::document() must run to regenerate NAMESPACE and man pages.
staged_wrappers=$(echo "$STAGED" | grep -E '(^|/)R/[a-z]+-wrappers\.R$' || true)
staged_namespace=$(echo "$STAGED" | grep -E '(^|/)NAMESPACE$' || true)

if [ -n "$staged_wrappers" ] && [ -z "$staged_namespace" ]; then
    echo "pre-commit: staged *-wrappers.R but NAMESPACE was not updated." >&2
    echo "  Run: just devtools-document" >&2
    echo "  Then stage the updated NAMESPACE and man/ pages." >&2
    echo "  Staged wrapper files:" >&2
    printf '    %s\n' $staged_wrappers >&2
    exit 1
fi

exit 0
